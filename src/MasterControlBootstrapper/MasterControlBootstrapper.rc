// Master Control Orchestration Server -- bootstrapper / launcher / setup.
// Used by all three sibling EXEs (MasterControlBootstrapper.exe,
// MasterControlOrchestrationServer.exe launcher,
// MasterControlOrchestrationServerSetup.exe). The OS surfaces the actual
// filename via its own metadata; the strings below describe the suite.
1 ICON "../../resources/icons/master-control.ico"

// VERSIONINFO -- baked into all three EXEs so Properties -> Details
// reports the live VERSION.json value.
#include <winres.h>

1 VERSIONINFO
 FILEVERSION    0,9,3,0
 PRODUCTVERSION 0,9,3,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "James Daley"
            VALUE "FileDescription",  "Master Control Orchestration Server -- Setup / Bootstrapper"
            VALUE "FileVersion",      "0.9.3.0"
            VALUE "InternalName",     "MasterControlBootstrapper"
            VALUE "LegalCopyright",   "Copyright (c) 2026 James Daley. All Rights Reserved."
            VALUE "OriginalFilename", "MasterControlBootstrapper.exe"
            VALUE "ProductName",      "Master Control Orchestration Server"
            VALUE "ProductVersion",   "0.9.3.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
