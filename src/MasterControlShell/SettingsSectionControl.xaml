<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.SettingsSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Guided Host Settings" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Use the host-settings wizard first when you want to shape ports, beacon behavior, and the governed resource envelope. The cards below remain as the live reference view." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />
                    <Grid>
                        <Button Tag="guided-settings" Click="GuidedSettingsActionButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Host Settings" HorizontalAlignment="Left" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Resource Envelope" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="ResourceEnvelopeText" Style="{StaticResource ShellDataTextStyle}" />
                    <TextBlock Text="Configuration File" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBlock x:Name="ConfigPathText" Style="{StaticResource ShellDataTextStyle}" />
                    <TextBlock Text="Data Directory" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBlock x:Name="DataDirectoryText" Style="{StaticResource ShellDataTextStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <TextBlock x:Name="ConfigurationNarrativeText" Style="{StaticResource ShellDataTextStyle}" Text="Configuration details will populate here." />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
