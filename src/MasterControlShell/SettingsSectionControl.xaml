<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.SettingsSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <!-- v0.8.5 Host Controls. Operator-driven service + dashboard
                 + filesystem actions. Moved here from the persistent shell
                 hero header so they live only on the Settings tab. Each
                 click handler emits an action token to MainWindow via the
                 actionRequested_ callback wired in AttachRuntime. -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Host Controls" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Operate the local Master Control service and inspect its on-disk state. These actions affect this host only."
                               Style="{StaticResource ShellBodyTextStyle}"
                               TextWrapping="WrapWholeWords" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="HostRefreshButton" Click="HostControlButton_Click" Tag="host-control:refresh" Style="{StaticResource ShellCommandButtonStyle}" Content="Refresh" />
                        <Button x:Name="HostStartServiceButton" Grid.Column="1" Click="HostControlButton_Click" Tag="host-control:start-service" Style="{StaticResource ShellCommandButtonStyle}" Content="Start Service" />
                        <Button x:Name="HostStopServiceButton" Grid.Row="1" Click="HostControlButton_Click" Tag="host-control:stop-service" Style="{StaticResource ShellCommandButtonStyle}" Content="Stop Service" />
                        <Button x:Name="HostOpenDashboardButton" Grid.Row="1" Grid.Column="1" Click="HostControlButton_Click" Tag="host-control:open-dashboard" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Dashboard" />
                        <Button x:Name="HostOpenConfigButton" Grid.Row="2" Click="HostControlButton_Click" Tag="host-control:open-config" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Config" />
                        <Button x:Name="HostOpenDataButton" Grid.Row="2" Grid.Column="1" Click="HostControlButton_Click" Tag="host-control:open-data" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Data" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- v0.8.5 Guided Setup Wizards. Buttons emit workflow tokens
                 to MainWindow's StartGuidedWorkflow via actionRequested_. -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Guided Setup Wizards" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Use guided setup to deploy and maintain runtime lanes, harden security, shape host settings, and manage Forsetti modules without digging through raw admin forms."
                               Style="{StaticResource ShellBodyTextStyle}"
                               TextWrapping="WrapWholeWords" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="WizardNewMcpButton" Click="GuidedWizardButton_Click" Tag="new-mcp" Style="{StaticResource ShellCommandButtonStyle}" Content="New MCP Server" />
                        <Button x:Name="WizardManageRuntimeButton" Grid.Column="1" Click="GuidedWizardButton_Click" Tag="guided-runtime-maintenance" Style="{StaticResource ShellCommandButtonStyle}" Content="Manage Runtime Lanes" />
                        <Button x:Name="WizardNewSubAgentButton" Grid.Row="1" Click="GuidedWizardButton_Click" Tag="new-subagent" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent" />
                        <Button x:Name="WizardNewSubAgentGroupButton" Grid.Row="1" Grid.Column="1" Click="GuidedWizardButton_Click" Tag="new-subagent-group" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent Group" />
                        <Button x:Name="WizardNewAppleHostButton" Grid.Row="2" Click="GuidedWizardButton_Click" Tag="new-apple-host" Style="{StaticResource ShellCommandButtonStyle}" Content="New Apple Host" />
                        <Button x:Name="WizardForsettiModulesButton" Grid.Row="2" Grid.Column="1" Click="GuidedWizardButton_Click" Tag="manage-forsetti-modules" Style="{StaticResource ShellCommandButtonStyle}" Content="Manage Forsetti Modules" />
                        <Button x:Name="WizardImportButton" Grid.Row="3" Click="GuidedWizardButton_Click" Tag="guided-import" Style="{StaticResource ShellCommandButtonStyle}" Content="Guided Import" />
                        <Button x:Name="WizardSecurityButton" Grid.Row="3" Grid.Column="1" Click="GuidedWizardButton_Click" Tag="guided-security" Style="{StaticResource ShellCommandButtonStyle}" Content="Security Hardening" />
                        <Button x:Name="WizardSettingsButton" Grid.Row="4" Grid.ColumnSpan="2" Click="GuidedWizardButton_Click" Tag="guided-settings" Style="{StaticResource ShellCommandButtonStyle}" Content="Host Settings" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Guided Host Settings" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Configure this host directly here. Change the instance identity, bind ports, beacon behavior, and governed resource envelope, then apply the update through the local admin API." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                    <TextBlock Text="Instance Name" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="InstanceNameTextBox" TextChanged="SettingsEditor_TextChanged" PlaceholderText="Master Control Orchestration Server" />

                    <TextBlock Text="Bind Address" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="BindAddressTextBox" TextChanged="SettingsEditor_TextChanged" PlaceholderText="0.0.0.0" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Browser Port" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="BrowserPortTextBox" TextChanged="SettingsEditor_TextChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Beacon Port" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="BeaconPortTextBox" TextChanged="SettingsEditor_TextChanged" />
                        </StackPanel>
                    </Grid>

                    <ToggleSwitch x:Name="BeaconEnabledToggle" Header="Broadcast LAN beacon and gateway metadata" Toggled="SettingsToggle_Toggled" />

                    <TextBlock Text="Resource Allocation" Style="{StaticResource ShellLabelTextStyle}" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="CPU Allocation %" Style="{StaticResource ShellLabelTextStyle}" />
                            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="CpuAllocationSlider" Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="10" TickFrequency="10" TickPlacement="Outside" ValueChanged="AllocationSlider_ValueChanged" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="CpuAllocationTextBox" Width="64" TextAlignment="Right" MaxLength="3" TextChanged="AllocationTextBox_TextChanged" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Memory Allocation %" Style="{StaticResource ShellLabelTextStyle}" />
                            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="MemoryAllocationSlider" Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="10" TickFrequency="10" TickPlacement="Outside" ValueChanged="AllocationSlider_ValueChanged" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="MemoryAllocationTextBox" Width="64" TextAlignment="Right" MaxLength="3" TextChanged="AllocationTextBox_TextChanged" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Spacing="8">
                            <TextBlock Text="Bandwidth Allocation %" Style="{StaticResource ShellLabelTextStyle}" />
                            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="BandwidthAllocationSlider" Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="10" TickFrequency="10" TickPlacement="Outside" ValueChanged="AllocationSlider_ValueChanged" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="BandwidthAllocationTextBox" Width="64" TextAlignment="Right" MaxLength="3" TextChanged="AllocationTextBox_TextChanged" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8">
                            <TextBlock Text="Storage Allocation %" Style="{StaticResource ShellLabelTextStyle}" />
                            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="StorageAllocationSlider" Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="10" TickFrequency="10" TickPlacement="Outside" ValueChanged="AllocationSlider_ValueChanged" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="StorageAllocationTextBox" Width="64" TextAlignment="Right" MaxLength="3" TextChanged="AllocationTextBox_TextChanged" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="SettingsSummaryText" Style="{StaticResource ShellDataTextStyle}" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="SettingsStatusText" Style="{StaticResource ShellDataTextStyle}" Text="Host settings are applied through the local admin API." TextWrapping="WrapWholeWords" />
                    <Button x:Name="ApplySettingsButton" Click="ApplySettingsButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Apply Host Settings" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Resource Envelope" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="ResourceEnvelopeText" Style="{StaticResource ShellDataTextStyle}" />
                    <TextBlock Text="Configuration File" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBlock x:Name="ConfigPathText" Style="{StaticResource ShellDataTextStyle}" />
                    <TextBlock Text="Data Directory" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBlock x:Name="DataDirectoryText" Style="{StaticResource ShellDataTextStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <TextBlock x:Name="ConfigurationNarrativeText" Style="{StaticResource ShellDataTextStyle}" Text="Configuration details will populate here." />
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="LAN Advertising and Windows Firewall" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords"
                               Text="MCOS advertises itself on the LAN via Win32 DNS-SD (Bonjour-compatible), a UDP JSON beacon, and the discovery document at /.well-known/mcos.json. Advertising fires whenever this service is running, but the host firewall must allow the inbound ports below or LAN clients will see nothing. Run each snippet from an elevated PowerShell. Admin rights are required." />

                    <TextBlock x:Name="FirewallAdvertisingSummaryText" Style="{StaticResource ShellDataTextStyle}" TextWrapping="WrapWholeWords" />

                    <TextBlock Text="Inbound rule 1 of 4 - MCP Gateway (TCP, the AI-client surface)" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="FirewallGatewayRuleTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Code, Consolas" />
                    <Button x:Name="CopyFirewallGatewayRuleButton" Click="CopyFirewallGatewayRuleButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Copy snippet" HorizontalAlignment="Left" />

                    <TextBlock Text="Inbound rule 2 of 4 - Operator surface (TCP, the dashboard and admin API)" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="FirewallOperatorRuleTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Code, Consolas" />
                    <Button x:Name="CopyFirewallOperatorRuleButton" Click="CopyFirewallOperatorRuleButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Copy snippet" HorizontalAlignment="Left" />

                    <TextBlock Text="Inbound rule 3 of 4 - DNS-SD / mDNS (UDP 5353, the Bonjour advertising path)" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="FirewallMDnsRuleTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Code, Consolas" />
                    <Button x:Name="CopyFirewallMDnsRuleButton" Click="CopyFirewallMDnsRuleButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Copy snippet" HorizontalAlignment="Left" />

                    <TextBlock Text="Inbound rule 4 of 4 - Discovery beacon (UDP, legacy JSON broadcast)" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="FirewallBeaconRuleTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Code, Consolas" />
                    <Button x:Name="CopyFirewallBeaconRuleButton" Click="CopyFirewallBeaconRuleButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Copy snippet" HorizontalAlignment="Left" />

                    <TextBlock Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords"
                               Text="Profile=Private,Domain on every rule keeps MCOS off the Public profile. If your LAN is currently on the Public profile, reclassify the network in Windows Settings before applying these rules. To remove the rules later, run: Get-NetFirewallRule -DisplayName 'MCOS *' | Remove-NetFirewallRule" />

                    <TextBlock Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords"
                               Text="Verification: from another machine on the LAN, run Test-NetConnection -ComputerName &lt;this-host-ip&gt; -Port &lt;gateway-port&gt;. From a Public-profile network the same call should fail. mDNS browsing requires a Bonjour-aware tool such as 'dns-sd -B _mcos._tcp' on macOS or 'avahi-browse _mcos._tcp' on Linux. The full operations runbook lives at docs/wiki/Operations/Windows-Firewall-LAN-Mode.md." />

                    <TextBlock x:Name="FirewallCopyStatusText" Style="{StaticResource ShellDataTextStyle}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
