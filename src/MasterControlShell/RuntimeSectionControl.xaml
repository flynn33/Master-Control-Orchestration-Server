<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.RuntimeSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Guided Runtime Workflows" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Use the guided runtime workflows first when you want to publish or maintain MCP servers, custom sub-agents, and Apple hosts. The editors below remain available for advanced direct control." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Tag="guided-runtime-maintenance" Click="GuidedRuntimeActionButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Manage Runtime Lanes" />
                        <Button Grid.Row="0" Grid.Column="1" Tag="new-mcp" Click="GuidedRuntimeActionButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New MCP Server" />
                        <Button Grid.Row="1" Grid.Column="0" Tag="new-subagent" Click="GuidedRuntimeActionButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent" />
                        <Button Grid.Row="1" Grid.Column="1" Tag="new-apple-host" Click="GuidedRuntimeActionButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Apple Host" />
                    </Grid>
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ACTIVE LANES" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="RuntimeCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <TextBlock x:Name="RuntimeNarrativeText" Style="{StaticResource ShellBodyTextStyle}" Text="Runtime details will populate here." />
                </Border>
            </Grid>

            <!-- v0.8.3 MCP Servers card grid. Mirror of the Sub-Agents
                 card grid below; same per-card layout (name, reachability
                 dot, utilization bar with active/capacity ratio,
                 host:port, active-client roster) but driven from
                 snapshot.mcpServerRuntimeStats. Built imperatively in
                 RuntimeSectionControl::PopulateMcpServerCards. Operator
                 pointed out that the inventory has 17+ MCP servers and
                 they had no card surface; v0.8.3 closes that gap. -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="MCP Servers" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="McpServersHeadlineText" Style="{StaticResource ShellLabelTextStyle}" Text="Loading MCP server telemetry..." />
                    <StackPanel x:Name="McpServersCardStack" Spacing="10" />
                </StackPanel>
            </Border>

            <!-- v0.7.6: Sub-Agents card grid. Each sub-agent renders as a
                 card with its utilization bar, reachability dot, endpoint
                 host:port, and active-client list. The cards are built
                 imperatively in RuntimeSectionControl::ApplySnapshot from
                 snapshot.subAgentRuntimeStats. -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Sub-Agents" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="SubAgentsHeadlineText" Style="{StaticResource ShellLabelTextStyle}" Text="Loading sub-agent telemetry..." />
                    <StackPanel x:Name="SubAgentsCardStack" Spacing="10" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Platform Gateway Lanes" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="PlatformGatewaysListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="320" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Apple Remote Hosts" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="AppleRemoteHostsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="320" Style="{StaticResource ShellListViewStyle}" />

                        <TextBlock Text="Apple Host" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox x:Name="AppleHostSelector" SelectionChanged="AppleHostSelector_SelectionChanged" PlaceholderText="Choose a registered Apple remote host" />

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Host ID" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostIdTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="apple-host-01" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Display Name" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostDisplayNameTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="Primary Apple Build Host" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Transport" Style="{StaticResource ShellLabelTextStyle}" />
                                <ComboBox x:Name="AppleHostTransportComboBox" SelectionChanged="AppleHostTransportComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Companion Service" Tag="companion_service" />
                                    <ComboBoxItem Content="SSH" Tag="ssh" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Address or Hostname" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostAddressTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="mac-builder.local or 192.168.1.40" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="Port" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostPortTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="22 or 8081" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Username" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostUsernameTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="builder" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Companion Base URL" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostServiceBaseUrlTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="http://mac-builder.local:8081" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Companion Health Path" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostHealthPathTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="/healthz" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Companion Execute Path" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostExecutePathTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="/execute" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Preferred Developer Directory" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBox x:Name="AppleHostDeveloperDirectoryTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="/Applications/Xcode.app/Contents/Developer" />

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Default Signing Identity" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostSigningIdentityTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="Developer ID Application: Example Corp" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Default Notary Profile" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="AppleHostNotaryProfileTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="mastercontrol-notary" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Default Notary Team ID" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBox x:Name="AppleHostTeamIdTextBox" TextChanged="AppleHostEditor_TextChanged" PlaceholderText="ABCDE12345" />

                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <CheckBox x:Name="AppleHostMacPlatformCheckBox" Content="macOS" Click="AppleHostEnabledCheckBox_Click" />
                            <CheckBox x:Name="AppleHostIosPlatformCheckBox" Content="iOS" Click="AppleHostEnabledCheckBox_Click" />
                            <CheckBox x:Name="AppleHostEnabledCheckBox" Content="Enabled" Click="AppleHostEnabledCheckBox_Click" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="SaveAppleHostButton" Click="SaveAppleHostButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Apple Host" />
                            <Button x:Name="NewAppleHostButton" Click="NewAppleHostButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Apple Host" />
                            <Button x:Name="RemoveAppleHostButton" Click="RemoveAppleHostButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Remove Apple Host" />
                        </StackPanel>

                        <TextBlock x:Name="AppleHostStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No Apple remote host changes are staged." TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="AppleHostReadinessDetailsText" Style="{StaticResource ShellDataTextStyle}" Text="Apple host readiness details will appear here." TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Custom MCP Servers" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Define user-managed MCP server endpoints here so every provider can share the same tool plane without importing a package first." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                    <TextBlock Text="MCP Server" Style="{StaticResource ShellLabelTextStyle}" />
                    <ComboBox x:Name="CustomMcpServerSelector" SelectionChanged="CustomMcpServerSelector_SelectionChanged" PlaceholderText="Choose a saved MCP server" />

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Server ID" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomMcpServerIdTextBox" TextChanged="CustomMcpServerEditor_TextChanged" PlaceholderText="swift-tools-mcp" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Display Name" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomMcpServerDisplayNameTextBox" TextChanged="CustomMcpServerEditor_TextChanged" PlaceholderText="Swift Tools MCP" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Host" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomMcpServerHostTextBox" TextChanged="CustomMcpServerEditor_TextChanged" PlaceholderText="127.0.0.1 or LAN host" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Port" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomMcpServerPortTextBox" TextChanged="CustomMcpServerEditor_TextChanged" PlaceholderText="7302" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="8">
                            <TextBlock Text="Protocol" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomMcpServerProtocolTextBox" TextChanged="CustomMcpServerEditor_TextChanged" PlaceholderText="http or https" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Route Path" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="CustomMcpServerRoutePathTextBox" TextChanged="CustomMcpServerEditor_TextChanged" PlaceholderText="/mcp or /status" />

                    <TextBlock Text="Description" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="CustomMcpServerDescriptionTextBox" TextChanged="CustomMcpServerEditor_TextChanged" AcceptsReturn="True" Height="72" TextWrapping="Wrap" PlaceholderText="Optional notes about this MCP server, toolset, or intended lane." />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="SaveCustomMcpServerButton" Click="SaveCustomMcpServerButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save MCP Server" />
                        <Button x:Name="NewCustomMcpServerButton" Click="NewCustomMcpServerButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New MCP Server" />
                        <Button x:Name="RemoveCustomMcpServerButton" Click="RemoveCustomMcpServerButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Remove MCP Server" />
                    </StackPanel>

                    <TextBlock x:Name="CustomMcpServerStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No custom MCP server changes are staged." TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Custom Sub-Agents" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Define specialist lanes here so the runtime can route providers to user-created sub-agents just like imported or seeded agents." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                    <TextBlock Text="Sub-Agent" Style="{StaticResource ShellLabelTextStyle}" />
                    <ComboBox x:Name="CustomSubAgentSelector" SelectionChanged="CustomSubAgentSelector_SelectionChanged" PlaceholderText="Choose a saved specialist lane" />

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Sub-Agent ID" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentIdTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="swift-specialist" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Display Name" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentDisplayNameTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="Swift Specialist" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Specialization" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="CustomSubAgentSpecializationTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="Swift, C++, documentation, test automation..." />

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Host" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentHostTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="Optional bind or LAN host" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Port" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentPortTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="8">
                            <TextBlock Text="Protocol" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentProtocolTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="virtual or http" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Route Path" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="CustomSubAgentRoutePathTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="/status or blank for logical lanes" />

                    <TextBlock Text="Description" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="CustomSubAgentDescriptionTextBox" TextChanged="CustomSubAgentEditor_TextChanged" AcceptsReturn="True" Height="72" TextWrapping="Wrap" PlaceholderText="Optional notes about the specialist lane, purpose, or operating doctrine." />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="SaveCustomSubAgentButton" Click="SaveCustomSubAgentButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Sub-Agent" />
                        <Button x:Name="NewCustomSubAgentButton" Click="NewCustomSubAgentButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent" />
                        <Button x:Name="RemoveCustomSubAgentButton" Click="RemoveCustomSubAgentButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Remove Sub-Agent" />
                    </StackPanel>

                    <TextBlock x:Name="CustomSubAgentStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No custom sub-agent changes are staged." TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Runtime Endpoints" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <ListView x:Name="EndpointsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="680" Style="{StaticResource ShellListViewStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
