<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.RuntimeSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ACTIVE LANES" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="RuntimeCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <TextBlock x:Name="RuntimeNarrativeText" Style="{StaticResource ShellBodyTextStyle}" Text="Runtime details will populate here." />
                </Border>
            </Grid>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Custom Sub-Agents" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Define specialist lanes here so the runtime can route providers to user-created sub-agents just like imported or seeded agents." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                    <TextBlock Text="Sub-Agent" Style="{StaticResource ShellLabelTextStyle}" />
                    <ComboBox x:Name="CustomSubAgentSelector" SelectionChanged="CustomSubAgentSelector_SelectionChanged" PlaceholderText="Choose a saved specialist lane" />

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Sub-Agent ID" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentIdTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="swift-specialist" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Display Name" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentDisplayNameTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="Swift Specialist" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Specialization" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="CustomSubAgentSpecializationTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="Swift, C++, documentation, test automation..." />

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Host" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentHostTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="Optional bind or LAN host" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Port" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentPortTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="8">
                            <TextBlock Text="Protocol" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBox x:Name="CustomSubAgentProtocolTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="virtual or http" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Route Path" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="CustomSubAgentRoutePathTextBox" TextChanged="CustomSubAgentEditor_TextChanged" PlaceholderText="/status or blank for logical lanes" />

                    <TextBlock Text="Description" Style="{StaticResource ShellLabelTextStyle}" />
                    <TextBox x:Name="CustomSubAgentDescriptionTextBox" TextChanged="CustomSubAgentEditor_TextChanged" AcceptsReturn="True" Height="72" TextWrapping="Wrap" PlaceholderText="Optional notes about the specialist lane, purpose, or operating doctrine." />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="SaveCustomSubAgentButton" Click="SaveCustomSubAgentButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Sub-Agent" />
                        <Button x:Name="NewCustomSubAgentButton" Click="NewCustomSubAgentButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent" />
                        <Button x:Name="RemoveCustomSubAgentButton" Click="RemoveCustomSubAgentButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Remove Sub-Agent" />
                    </StackPanel>

                    <TextBlock x:Name="CustomSubAgentStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No custom sub-agent changes are staged." TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Runtime Endpoints" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <ListView x:Name="EndpointsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="680" Style="{StaticResource ShellListViewStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
