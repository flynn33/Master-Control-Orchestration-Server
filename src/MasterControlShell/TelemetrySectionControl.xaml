<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.TelemetrySectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource ShellHeroCardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <TextBlock Text="PRIMARY MONITORING SURFACE" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock x:Name="TelemetryHeadlineText" Text="Telemetry Grid" Style="{StaticResource ShellHeroTitleTextStyle}" />
                        <TextBlock x:Name="TelemetrySummaryText" Style="{StaticResource ShellBodyTextStyle}" Text="Waiting for a live telemetry snapshot from the local orchestration service." />
                        <TextBlock x:Name="TelemetryCaptureText" Style="{StaticResource ShellLabelTextStyle}" Text="Capture timestamp pending." />
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="HOST IDENTITY" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock x:Name="HostIdentityText" Style="{StaticResource ShellDataTextStyle}" Text="Awaiting host identity." />
                            <TextBlock x:Name="EnvironmentProfileText" Style="{StaticResource ShellDataTextStyle}" Text="Environment profile pending." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="CONTROL PLANE ACCESS" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock x:Name="TelemetryServiceSummaryText" Style="{StaticResource ShellDataTextStyle}" Text="Service posture pending." />
                            <TextBlock x:Name="TelemetryPathsText" Style="{StaticResource ShellDataTextStyle}" Text="Runtime paths pending." />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="20">
                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Live Host Pressure" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <Grid ColumnSpacing="14" RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="CPU LOAD" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="CpuValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressBar x:Name="CpuProgressBar" Height="8" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="CpuDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Live host utilization." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="MEMORY PRESSURE" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="MemoryValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressBar x:Name="MemoryProgressBar" Height="8" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="MemoryDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Resident memory pressure." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="DISK OCCUPANCY" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="DiskValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressBar x:Name="DiskProgressBar" Height="8" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="DiskDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Payload and runtime storage pressure." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="TX THROUGHPUT" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="TxValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="TxDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Outbound network traffic." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="RX THROUGHPUT" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="RxValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="RxDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Inbound network traffic." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="LIVE TRAFFIC" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="TrafficValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="TrafficDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Combined transfer envelope." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Resource Allocation" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <Grid ColumnSpacing="14" RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="CPU BUDGET" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="CpuAllocationValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressBar x:Name="CpuAllocationProgressBar" Height="8" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="CpuAllocationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Governed launch budget." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="RAM BUDGET" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="MemoryAllocationValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressBar x:Name="MemoryAllocationProgressBar" Height="8" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="MemoryAllocationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Governed memory budget." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="BANDWIDTH BUDGET" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="BandwidthAllocationValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressBar x:Name="BandwidthAllocationProgressBar" Height="8" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="BandwidthAllocationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Governed transfer budget." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="STORAGE BUDGET" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="StorageAllocationValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressBar x:Name="StorageAllocationProgressBar" Height="8" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="StorageAllocationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Governed storage budget." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Operational Activity" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <Grid ColumnSpacing="14" RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="RUNTIME LANES" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="EndpointCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="EndpointCountDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Published service lanes." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="GOVERNANCE FINDINGS" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="GovernanceFindingCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="GovernanceFindingDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Live CLU posture findings." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="APPLE OPERATIONS" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="AppleOperationCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="AppleOperationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Remote Apple jobs tracked." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="PLATFORM GATEWAYS" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="PlatformGatewayCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="PlatformGatewayDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Published platform lanes." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="GOVERNANCE SERVERS" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBlock x:Name="GovernanceServerCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="GovernanceServerDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Execution endpoints available." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="20">
                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Service + Security Posture" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock x:Name="ControlPlanePostureText" Style="{StaticResource ShellDataTextStyle}" Text="Control plane posture will populate here." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Runtime Routes" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock x:Name="TelemetryRoutingText" Style="{StaticResource ShellDataTextStyle}" Text="Runtime route summary will populate here." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Telemetry Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock x:Name="TelemetryNarrativeText" Style="{StaticResource ShellDataTextStyle}" Text="Telemetry narrative will populate here." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Environment Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock x:Name="EnvironmentNarrativeText" Style="{StaticResource ShellDataTextStyle}" Text="Environment details will populate here." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
