<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.TelemetrySectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource ShellHeroCardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <TextBlock Text="PRIMARY MONITORING SURFACE" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock x:Name="TelemetryHeadlineText" Text="Telemetry Grid" Style="{StaticResource ShellHeroTitleTextStyle}" />
                        <TextBlock x:Name="TelemetrySummaryText" Style="{StaticResource ShellBodyTextStyle}" Text="Waiting for a live telemetry snapshot from the local orchestration service." />
                        <TextBlock x:Name="TelemetryCaptureText" Style="{StaticResource ShellLabelTextStyle}" Text="Capture timestamp pending." />
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="HOST IDENTITY" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock x:Name="HostIdentityText" Style="{StaticResource ShellDataTextStyle}" Text="Awaiting host identity." />
                            <TextBlock x:Name="EnvironmentProfileText" Style="{StaticResource ShellDataTextStyle}" Text="Environment profile pending." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="CONTROL PLANE ACCESS" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock x:Name="TelemetryServiceSummaryText" Style="{StaticResource ShellDataTextStyle}" Text="Service posture pending." />
                            <TextBlock x:Name="TelemetryPathsText" Style="{StaticResource ShellDataTextStyle}" Text="Runtime paths pending." />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- v0.8.0: Customize Layout bar. The user controls which
                 telemetry tiles render (Customize flyout), can drag-drop
                 tiles to swap positions inside each section, and can pop
                 any tile to its own desktop window via the small detach
                 button on each tile. Layout persists to the runtime data
                 directory's telemetry-layout.json. -->
            <Border Style="{StaticResource ShellCardStyle}">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="TELEMETRY LAYOUT" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Drag tiles to reorder. Use the buttons on each tile to detach or hide it." Style="{StaticResource ShellLabelTextStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="LayoutStatusText" Style="{StaticResource ShellLabelTextStyle}" Text="" VerticalAlignment="Center" />
                    <Button Grid.Column="2" x:Name="CustomizeLayoutButton" Style="{StaticResource ShellCommandButtonStyle}" Content="Customize Layout">
                        <Button.Flyout>
                            <Flyout x:Name="CustomizeLayoutFlyout">
                                <StackPanel Spacing="10" MinWidth="280">
                                    <TextBlock Text="VISIBLE TELEMETRY TILES" Style="{StaticResource ShellEyebrowTextStyle}" />
                                    <StackPanel x:Name="CustomizeTileCheckboxStack" Spacing="6" />
                                    <TextBlock Text="Drag tiles in the grid to swap positions. Detach pops a tile to its own desktop window." Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" />
                                    <Button x:Name="ResetLayoutButton" Click="ResetLayoutButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Reset to defaults" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="20">
                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Live Host Pressure" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <Grid x:Name="HostPressureGrid" ColumnSpacing="14" RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="CpuTile" Tag="CpuTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="CPU LOAD" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="CpuStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="CpuTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="CpuTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="CpuValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressRing x:Name="CpuProgressBar" IsActive="True" IsIndeterminate="False" Maximum="100" Width="72" Height="72" HorizontalAlignment="Left" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="CpuDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Live host utilization." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="MemoryTile" Tag="MemoryTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="MEMORY PRESSURE" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="MemoryStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="MemoryTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="MemoryTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="MemoryValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressRing x:Name="MemoryProgressBar" IsActive="True" IsIndeterminate="False" Maximum="100" Width="72" Height="72" HorizontalAlignment="Left" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="MemoryDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Resident memory pressure." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="DiskTile" Tag="DiskTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="DISK OCCUPANCY" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="DiskStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="DiskTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="DiskTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="DiskValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressRing x:Name="DiskProgressBar" IsActive="True" IsIndeterminate="False" Maximum="100" Width="72" Height="72" HorizontalAlignment="Left" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="DiskDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Payload and runtime storage pressure." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="TxTile" Tag="TxTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Row="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="TX THROUGHPUT" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="TxStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="TxTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="TxTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="TxValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="TxDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Outbound network traffic." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="RxTile" Tag="RxTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Row="1" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="RX THROUGHPUT" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="RxStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="RxTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="RxTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="RxValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="RxDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Inbound network traffic." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="TrafficTile" Tag="TrafficTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Row="1" Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="LIVE TRAFFIC" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="TrafficStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="TrafficTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="TrafficTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="TrafficValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="TrafficDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Combined transfer envelope." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Resource Allocation" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <Grid x:Name="ResourceAllocationGrid" ColumnSpacing="14" RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="CpuBudgetTile" Tag="CpuBudgetTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="CPU BUDGET" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="CpuAllocationStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="CpuBudgetTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="CpuBudgetTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="CpuAllocationValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressRing x:Name="CpuAllocationProgressBar" IsActive="True" IsIndeterminate="False" Maximum="100" Width="72" Height="72" HorizontalAlignment="Left" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="CpuAllocationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Governed launch budget." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="RamBudgetTile" Tag="RamBudgetTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="RAM BUDGET" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="MemoryAllocationStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="RamBudgetTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="RamBudgetTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="MemoryAllocationValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressRing x:Name="MemoryAllocationProgressBar" IsActive="True" IsIndeterminate="False" Maximum="100" Width="72" Height="72" HorizontalAlignment="Left" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="MemoryAllocationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Governed memory budget." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="BandwidthBudgetTile" Tag="BandwidthBudgetTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Row="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="BANDWIDTH BUDGET" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="BandwidthAllocationStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="BandwidthBudgetTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="BandwidthBudgetTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="BandwidthAllocationValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressRing x:Name="BandwidthAllocationProgressBar" IsActive="True" IsIndeterminate="False" Maximum="100" Width="72" Height="72" HorizontalAlignment="Left" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="BandwidthAllocationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Governed transfer budget." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="StorageBudgetTile" Tag="StorageBudgetTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Row="1" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="STORAGE BUDGET" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="StorageAllocationStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="StorageBudgetTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="StorageBudgetTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="StorageAllocationValueText" Style="{StaticResource ShellValueTextStyle}" />
                                        <ProgressRing x:Name="StorageAllocationProgressBar" IsActive="True" IsIndeterminate="False" Maximum="100" Width="72" Height="72" HorizontalAlignment="Left" Foreground="{StaticResource ShellAccentBrush}" />
                                        <TextBlock x:Name="StorageAllocationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Governed storage budget." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Operational Activity" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <Grid x:Name="OperationalActivityGrid" ColumnSpacing="14" RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="RuntimeLanesTile" Tag="RuntimeLanesTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="RUNTIME LANES" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="EndpointCountStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="RuntimeLanesTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="RuntimeLanesTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="EndpointCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="EndpointCountDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Published service lanes." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="GovernanceFindingsTile" Tag="GovernanceFindingsTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="GOVERNANCE FINDINGS" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="GovernanceFindingStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="GovernanceFindingsTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="GovernanceFindingsTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="GovernanceFindingCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="GovernanceFindingDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Live CLU posture findings." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="AppleOperationsTile" Tag="AppleOperationsTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="APPLE OPERATIONS" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="AppleOperationStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="AppleOperationsTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="AppleOperationsTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="AppleOperationCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="AppleOperationDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Remote Apple jobs tracked." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="PlatformGatewaysTile" Tag="PlatformGatewaysTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Row="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="PLATFORM GATEWAYS" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="PlatformGatewayStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="PlatformGatewaysTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="PlatformGatewaysTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="PlatformGatewayCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="PlatformGatewayDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Published platform lanes." />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="GovernanceServersTile" Tag="GovernanceServersTile" CanDrag="True" AllowDrop="True" DragStarting="Tile_DragStarting" Drop="Tile_Drop" DragOver="Tile_DragOver" Grid.Row="1" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="GOVERNANCE SERVERS" Style="{StaticResource ShellLabelTextStyle}" VerticalAlignment="Center" />
                                            <Border x:Name="GovernanceServerStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                            <Button Tag="GovernanceServersTile" Click="DetachButton_Click" Content="&#x2922;" ToolTipService.ToolTip="Detach to desktop" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                            <Button Tag="GovernanceServersTile" Click="HideButton_Click" Content="&#x2715;" ToolTipService.ToolTip="Hide tile" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                        <TextBlock x:Name="GovernanceServerCountText" Style="{StaticResource ShellValueTextStyle}" />
                                        <TextBlock x:Name="GovernanceServerDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Execution endpoints available." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="20">
                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Service + Security Posture" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock x:Name="ControlPlanePostureText" Style="{StaticResource ShellDataTextStyle}" Text="Control plane posture will populate here." />
                        </StackPanel>
                    </Border>

                    <!-- v0.9.79: compact Supervisor Agent status for the
                         Telemetry sidebar. The Overview surface owns the
                         full wizard (toggle group + Generate / Revoke).
                         The Telemetry sidebar is read-only: one-line
                         headline + one detail line so the operator can
                         see the current supervisor without leaving the
                         telemetry deck. Populated by ApplySupervisorTile
                         from snapshot.supervisorStatus. -->
                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="SUPERVISOR AGENT" Style="{StaticResource ShellEyebrowTextStyle}" />
                                <Border x:Name="TelemetrySupervisorStatusDot"
                                        Width="10" Height="10" CornerRadius="5,5,5,5"
                                        VerticalAlignment="Center"
                                        Background="#FF8CB7C4" />
                            </StackPanel>
                            <TextBlock x:Name="TelemetrySupervisorHeadline"
                                       Style="{StaticResource ShellDataTextStyle}"
                                       Text="No supervisor assigned." />
                            <TextBlock x:Name="TelemetrySupervisorDetail"
                                       Style="{StaticResource ShellLabelTextStyle}"
                                       Foreground="{StaticResource ShellTextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Text="Pick a supervisor model on the Overview deck." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Runtime Routes" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock x:Name="TelemetryRoutingText" Style="{StaticResource ShellDataTextStyle}" Text="Runtime route summary will populate here." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Telemetry Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock x:Name="TelemetryNarrativeText" Style="{StaticResource ShellDataTextStyle}" Text="Telemetry narrative will populate here." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Environment Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock x:Name="EnvironmentNarrativeText" Style="{StaticResource ShellDataTextStyle}" Text="Environment details will populate here." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- v0.9.76: MCP Servers + Sub-Agents card grids on the
                 Telemetry surface. Operator directive: WinUI is the
                 priority surface; mirror the browser's v0.9.70 Telemetry
                 deck so a remote-desktop session never has to bounce to
                 the Runtime tab to see per-endpoint live state. Cards
                 are built imperatively in TelemetrySectionControl::
                 PopulateMcpServerCards / PopulateSubAgentCards via the
                 shared EndpointStatCardGrid.h template. Same exact card
                 visuals used by RuntimeSectionControl + Overview surface
                 cards for consistency.
                 Fields shown per card:
                   - Status indicator: reachability dot + endpoint host:port
                     + status word.
                   - Usage indicator: utilization % label + ProgressBar
                     (good / warn / critical tone) + active / capacity
                     lease counter.
                   - Connected clients: per-IP + client-type rows, or a
                     muted "No active clients" line. -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="MCP Servers" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="TelemetryMcpServersHeadlineText" Style="{StaticResource ShellLabelTextStyle}" Text="Loading MCP server telemetry..." />
                    <StackPanel x:Name="TelemetryMcpServersCardStack" Spacing="10" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Sub-Agents" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="TelemetrySubAgentsHeadlineText" Style="{StaticResource ShellLabelTextStyle}" Text="Loading sub-agent telemetry..." />
                    <StackPanel x:Name="TelemetrySubAgentsCardStack" Spacing="10" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
