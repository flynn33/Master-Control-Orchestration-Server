<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.ExportsSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="20">
                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Export Control" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock Text="Preview generated agent artifacts, then export the selected item or the full bundle to the local exports directory." Style="{StaticResource ShellBodyTextStyle}" />

                        <TextBlock Text="Artifact" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox x:Name="ExportSelector" SelectionChanged="ExportSelector_SelectionChanged" PlaceholderText="Select an artifact" />

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="File Name" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBlock x:Name="SelectedExportFileNameText" Style="{StaticResource ShellDataTextStyle}" Text="No artifact selected" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Media Type" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBlock x:Name="SelectedExportMediaTypeText" Style="{StaticResource ShellDataTextStyle}" Text="n/a" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Artifact Preview" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBox
                            x:Name="ExportPreviewTextBox"
                            AcceptsReturn="True"
                            Height="320"
                            IsReadOnly="True"
                            TextWrapping="NoWrap" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="RefreshExportsButton" Click="RefreshExportsButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Refresh Artifacts" />
                            <Button x:Name="ExportSelectedButton" Click="ExportSelectedButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Export Selected" />
                            <Button x:Name="ExportAllButton" Click="ExportAllButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Export All" />
                            <Button x:Name="OpenExportFolderButton" Click="OpenExportFolderButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Export Folder" />
                        </StackPanel>

                        <TextBlock x:Name="ExportStatusText" Style="{StaticResource ShellDataTextStyle}" Text="Exports are generated by the local admin API and materialized into the local data directory." />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="20">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ShellMetricTileStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="EXPORT ARTIFACTS" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBlock x:Name="ExportArtifactCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="DashboardUrlText" Style="{StaticResource ShellDataTextStyle}" />
                            <TextBlock x:Name="ExportsNarrativeText" Style="{StaticResource ShellBodyTextStyle}" Text="Export details will populate here." />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Agent Exports" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="ExportsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="680" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
