<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.CommandLogicUnitSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="CLU POSTURE" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="CluPostureText" Style="{StaticResource ShellValueTextStyle}" Text="Pending" />
                        <TextBlock x:Name="CluFindingCountText" Style="{StaticResource ShellLabelTextStyle}" Text="0 findings" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ROLES" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="CluRoleCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                        <TextBlock Text="Published authorities" Style="{StaticResource ShellLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="RULES" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="CluRuleCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                        <TextBlock Text="Measured controls" Style="{StaticResource ShellLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="DOCUMENTS" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="CluDocumentCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                        <TextBlock x:Name="CluEvaluatedText" Style="{StaticResource ShellLabelTextStyle}" Text="Last evaluated: pending" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="APPLE HOSTS" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="CluAppleHostCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                        <TextBlock Text="Remote toolchain lanes" Style="{StaticResource ShellLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="APPLE OPS" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="CluAppleOperationCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                        <TextBlock Text="Queued and completed runs" Style="{StaticResource ShellLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="GATEWAYS" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="CluGatewayCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                        <TextBlock Text="Broadcast platform lanes" Style="{StaticResource ShellLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource ShellMetricTileStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="GOVERNANCE SERVERS" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBlock x:Name="CluGovernanceServerCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                        <TextBlock Text="Platform enforcement lanes" Style="{StaticResource ShellLabelTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Command Logic Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="CluNarrativeText" Style="{StaticResource ShellBodyTextStyle}" Text="CLU narrative will appear here." />
                        <Border Background="{StaticResource ShellPanelDeepBrush}" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="16" Padding="16">
                            <TextBlock x:Name="CluDoctrineText" Style="{StaticResource ShellDataTextStyle}" Text="CLU doctrine will appear here." />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Recommended Actions" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluActionsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="320" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Active Findings" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluFindingsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Roles" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluRolesListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Apple Remote Hosts" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluAppleHostsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Recent Apple Operations" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluAppleOperationsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                        <TextBlock Text="Replay Apple Operation" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox x:Name="AppleOperationSelector" SelectionChanged="AppleOperationSelector_SelectionChanged" PlaceholderText="Choose a recorded Apple operation" />
                        <Button x:Name="RerunAppleOperationButton" Click="RerunAppleOperationButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Rerun Apple Operation" />
                        <TextBlock x:Name="AppleOperationStatusText" Style="{StaticResource ShellDataTextStyle}" Text="Select an Apple operation to replay it through CLU." TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Platform Gateways" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluPlatformGatewaysListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Governance Servers" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluGovernanceServersListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Rules" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluRulesListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Published Documents" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="CluDocumentsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Recent Governance Executions" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <ListView x:Name="CluRecentExecutionsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="420" Style="{StaticResource ShellListViewStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
