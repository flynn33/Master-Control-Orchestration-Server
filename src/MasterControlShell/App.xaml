<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="MasterControlShell.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:MasterControlShell">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="ShellTextPrimaryBrush" Color="#E6FCFF" />
            <SolidColorBrush x:Key="ShellTextMutedBrush" Color="#8CB7C4" />
            <SolidColorBrush x:Key="ShellTextFaintBrush" Color="#6A8B95" />
            <SolidColorBrush x:Key="ShellAccentBrush" Color="#00F6FF" />
            <SolidColorBrush x:Key="ShellAccentSoftBrush" Color="#5500F6FF" />
            <SolidColorBrush x:Key="ShellGlowBrush" Color="#2200F6FF" />
            <SolidColorBrush x:Key="ShellSuccessBrush" Color="#1CF2C1" />
            <SolidColorBrush x:Key="ShellWarningBrush" Color="#FFC857" />
            <SolidColorBrush x:Key="ShellDangerBrush" Color="#FF6A80" />
            <SolidColorBrush x:Key="ShellPanelFillBrush" Color="#E0060A10" />
            <SolidColorBrush x:Key="ShellPanelDeepBrush" Color="#F003070C" />
            <SolidColorBrush x:Key="ShellCardFillBrush" Color="#E00A1018" />
            <SolidColorBrush x:Key="ShellCardEdgeBrush" Color="#5A00E8FF" />
            <SolidColorBrush x:Key="ShellTileFillBrush" Color="#E003070B" />
            <SolidColorBrush x:Key="ShellTileEdgeBrush" Color="#4400DFFF" />
            <SolidColorBrush x:Key="ShellGridlineBrush" Color="#2600DFFF" />

            <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#010205" Offset="0.0" />
                <GradientStop Color="#031018" Offset="0.22" />
                <GradientStop Color="#041C2A" Offset="0.56" />
                <GradientStop Color="#060A10" Offset="1.0" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="ShellHeroBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E0091620" Offset="0.0" />
                <GradientStop Color="#DD060C13" Offset="0.52" />
                <GradientStop Color="#E003070B" Offset="1.0" />
            </LinearGradientBrush>

            <Style x:Key="ShellCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellPanelFillBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellCardEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Padding" Value="14" />
            </Style>

            <Style x:Key="ShellHeroCardStyle" TargetType="Border" BasedOn="{StaticResource ShellCardStyle}">
                <Setter Property="Background" Value="{StaticResource ShellHeroBrush}" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="ShellMetricTileStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellPanelDeepBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellTileEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Padding" Value="12" />
            </Style>

            <!-- Compact variant modelled after the Tron command-center reference:
                 tighter padding, thinner inner spacing for dense metric grids. -->
            <Style x:Key="ShellCompactTileStyle" TargetType="Border" BasedOn="{StaticResource ShellMetricTileStyle}">
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="CornerRadius" Value="1" />
            </Style>

            <!-- Sub-agent footer badge: rounded pill with accent border, used for the
                 SENTINEL / ARCHITECT / FORGE / SCRIBE / RECON / NEXUS / WATCHDOG row. -->
            <Style x:Key="ShellSubAgentBadgeStyle" TargetType="Border">
                <Setter Property="Background" Value="#14000F16" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellTileEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="3" />
                <Setter Property="Padding" Value="10,7" />
                <Setter Property="MinWidth" Value="108" />
            </Style>

            <Style x:Key="ShellSubAgentBadgeTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="CharacterSpacing" Value="180" />
            </Style>

            <Style x:Key="ShellSubAgentBadgeSubtitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextMutedBrush}" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="CharacterSpacing" Value="80" />
            </Style>

            <Style x:Key="ShellLiveClockTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="CharacterSpacing" Value="60" />
            </Style>

            <Style x:Key="ShellEyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="CharacterSpacing" Value="160" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellHeroTitleTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellSectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="CharacterSpacing" Value="80" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellBodyTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellLabelTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextMutedBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="CharacterSpacing" Value="60" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellValueTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellDataTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellStatusTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellCommandButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="Background" Value="#F0071018" />
                <Setter Property="BorderBrush" Value="#9900E8FF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Padding" Value="14,12" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="CharacterSpacing" Value="40" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="MinHeight" Value="54" />
                <Setter Property="MinWidth" Value="176" />
            </Style>

            <Style x:Key="ShellSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCommandButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="Background" Value="#AA091118" />
                <Setter Property="BorderBrush" Value="#6600F6FF" />
            </Style>

            <SolidColorBrush x:Key="ShellFocusBrush" Color="#CC00F6FF" />
            <SolidColorBrush x:Key="ShellPressFillBrush" Color="#2200F6FF" />
            <SolidColorBrush x:Key="ShellSkeletonBrush" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="ShellSuccessSoftBrush" Color="#331CF2C1" />
            <SolidColorBrush x:Key="ShellWarningSoftBrush" Color="#33FFC857" />
            <SolidColorBrush x:Key="ShellDangerSoftBrush" Color="#33FF6A80" />

            <Style x:Key="ShellStatusChipStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellAccentSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ShellStatusChipTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="CharacterSpacing" Value="120" />
            </Style>

            <Style x:Key="ShellSuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCommandButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ShellSuccessBrush}" />
                <Setter Property="Background" Value="{StaticResource ShellSuccessSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellSuccessBrush}" />
            </Style>

            <Style x:Key="ShellWarningButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCommandButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ShellWarningBrush}" />
                <Setter Property="Background" Value="{StaticResource ShellWarningSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellWarningBrush}" />
            </Style>

            <Style x:Key="ShellDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCommandButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ShellDangerBrush}" />
                <Setter Property="Background" Value="{StaticResource ShellDangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellDangerBrush}" />
            </Style>

            <Style x:Key="ShellMetricLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ShellLabelTextStyle}">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="CharacterSpacing" Value="140" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="ShellMetricValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ShellValueTextStyle}">
                <Setter Property="FontSize" Value="24" />
            </Style>

            <Style x:Key="ShellSkeletonBlockStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellSkeletonBrush}" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Height" Value="14" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="ShellListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="MinHeight" Value="42" />
            </Style>

            <Style x:Key="ShellListViewStyle" TargetType="ListView">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="SelectionMode" Value="None" />
                <Setter Property="IsItemClickEnabled" Value="False" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource ShellListViewItemStyle}" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="#E0070E14" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellTileEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="MinHeight" Value="40" />
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="Background" Value="#E0070E14" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellTileEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="MinHeight" Value="40" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="#E0070E14" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellTileEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="MinHeight" Value="40" />
            </Style>

            <DataTemplate x:Key="ShellListItemTemplate">
                <Border
                    Margin="0,0,0,10"
                    Padding="10,8"
                    Background="{StaticResource ShellPanelDeepBrush}"
                    BorderBrush="{StaticResource ShellTileEdgeBrush}"
                    BorderThickness="1"
                    CornerRadius="3">
                    <TextBlock
                        Style="{StaticResource ShellDataTextStyle}"
                        Text="{Binding}"
                        TextWrapping="Wrap" />
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
