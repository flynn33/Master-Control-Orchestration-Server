<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="MasterControlShell.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:MasterControlShell">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <!-- Tron amplification v2: brighter cyan, higher-contrast panels,
                 thicker border alphas, more saturated danger/success accents.
                 Every panel is now a proper Tron glass pane — edges glow, text
                 on text sits in full-opacity cyan, background stays pitch. -->
            <SolidColorBrush x:Key="ShellTextPrimaryBrush" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ShellTextMutedBrush" Color="#9ECCDA" />
            <SolidColorBrush x:Key="ShellTextFaintBrush" Color="#7BA4B0" />
            <SolidColorBrush x:Key="ShellAccentBrush" Color="#00FFFF" />
            <SolidColorBrush x:Key="ShellAccentBrightBrush" Color="#7DFFFF" />
            <SolidColorBrush x:Key="ShellAccentSoftBrush" Color="#7000FFFF" />
            <SolidColorBrush x:Key="ShellGlowBrush" Color="#3300FFFF" />
            <SolidColorBrush x:Key="ShellHotGlowBrush" Color="#5500FFFF" />
            <SolidColorBrush x:Key="ShellSuccessBrush" Color="#3BFFCF" />
            <SolidColorBrush x:Key="ShellWarningBrush" Color="#FFD56B" />
            <SolidColorBrush x:Key="ShellDangerBrush" Color="#FF5577" />
            <SolidColorBrush x:Key="ShellPanelFillBrush" Color="#F0020810" />
            <SolidColorBrush x:Key="ShellPanelDeepBrush" Color="#F8020609" />
            <SolidColorBrush x:Key="ShellCardFillBrush" Color="#F00A1622" />
            <SolidColorBrush x:Key="ShellCardEdgeBrush" Color="#8800FFFF" />
            <SolidColorBrush x:Key="ShellTileFillBrush" Color="#F0040B14" />
            <SolidColorBrush x:Key="ShellTileEdgeBrush" Color="#6600FFFF" />
            <SolidColorBrush x:Key="ShellGridlineBrush" Color="#4400FFFF" />

            <!-- Deeper, more saturated Tron background gradient — pure near-black
                 with a cyan wash in the upper-left quadrant. Cards visibly glow
                 against it. -->
            <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#000000" Offset="0.0" />
                <GradientStop Color="#001420" Offset="0.22" />
                <GradientStop Color="#00283D" Offset="0.56" />
                <GradientStop Color="#000507" Offset="1.0" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="ShellHeroBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F00A2230" Offset="0.0" />
                <GradientStop Color="#F0061018" Offset="0.52" />
                <GradientStop Color="#F00A2536" Offset="1.0" />
            </LinearGradientBrush>

            <!-- Thicker borders and a more aggressive 0-corner-radius edge so
                 cards read as panels punched out of the grid. -->
            <Style x:Key="ShellCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellPanelFillBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellCardEdgeBrush}" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="14" />
            </Style>

            <Style x:Key="ShellHeroCardStyle" TargetType="Border" BasedOn="{StaticResource ShellCardStyle}">
                <Setter Property="Background" Value="{StaticResource ShellHeroBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="ShellMetricTileStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellPanelDeepBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellTileEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="12" />
            </Style>

            <!-- Compact variant modelled after the Tron command-center reference:
                 tighter padding, thinner inner spacing for dense metric grids. -->
            <Style x:Key="ShellCompactTileStyle" TargetType="Border" BasedOn="{StaticResource ShellMetricTileStyle}">
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="CornerRadius" Value="0" />
            </Style>

            <!-- Sub-agent footer badge: rounded pill with accent border, used for the
                 SENTINEL / ARCHITECT / FORGE / SCRIBE / RECON / NEXUS / WATCHDOG row. -->
            <Style x:Key="ShellSubAgentBadgeStyle" TargetType="Border">
                <Setter Property="Background" Value="#14000F16" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellTileEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="10,7" />
                <Setter Property="MinWidth" Value="108" />
            </Style>

            <Style x:Key="ShellSubAgentBadgeTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="CharacterSpacing" Value="180" />
            </Style>

            <Style x:Key="ShellSubAgentBadgeSubtitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextMutedBrush}" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="CharacterSpacing" Value="80" />
            </Style>

            <Style x:Key="ShellLiveClockTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="CharacterSpacing" Value="60" />
            </Style>

            <Style x:Key="ShellEyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="CharacterSpacing" Value="160" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellHeroTitleTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellSectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="CharacterSpacing" Value="80" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellBodyTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellLabelTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextMutedBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="CharacterSpacing" Value="60" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellValueTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellDataTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ShellStatusTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- Unified button sizing so every action row renders at the
                 same height whether the button uses the implicit style or
                 one of the named styles (Command / Secondary / Success /
                 Warning / Danger). MinHeight 48 + Padding 12,10 is the
                 single baseline; named styles only change color tone. -->
            <Style x:Key="ShellCommandButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="Background" Value="#F0071018" />
                <Setter Property="BorderBrush" Value="#9900E8FF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="CharacterSpacing" Value="40" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="MinHeight" Value="48" />
            </Style>

            <!-- Secondary: visibly recessive vs primary. Lower opacity fill
                 + dimmer border so destination CTAs win the eye. -->
            <Style x:Key="ShellSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCommandButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="Background" Value="#55050B12" />
                <Setter Property="BorderBrush" Value="#4400F6FF" />
                <Setter Property="FontWeight" Value="Normal" />
            </Style>

            <SolidColorBrush x:Key="ShellFocusBrush" Color="#CC00F6FF" />
            <SolidColorBrush x:Key="ShellPressFillBrush" Color="#2200F6FF" />
            <SolidColorBrush x:Key="ShellSkeletonBrush" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="ShellSuccessSoftBrush" Color="#331CF2C1" />
            <SolidColorBrush x:Key="ShellWarningSoftBrush" Color="#33FFC857" />
            <SolidColorBrush x:Key="ShellDangerSoftBrush" Color="#33FF6A80" />

            <Style x:Key="ShellStatusChipStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellAccentSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ShellStatusChipTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="CharacterSpacing" Value="120" />
            </Style>

            <Style x:Key="ShellSuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCommandButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ShellSuccessBrush}" />
                <Setter Property="Background" Value="{StaticResource ShellSuccessSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellSuccessBrush}" />
            </Style>

            <Style x:Key="ShellWarningButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCommandButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ShellWarningBrush}" />
                <Setter Property="Background" Value="{StaticResource ShellWarningSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellWarningBrush}" />
            </Style>

            <Style x:Key="ShellDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCommandButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource ShellDangerBrush}" />
                <Setter Property="Background" Value="{StaticResource ShellDangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellDangerBrush}" />
            </Style>

            <Style x:Key="ShellMetricLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ShellLabelTextStyle}">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="CharacterSpacing" Value="140" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="ShellMetricValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ShellValueTextStyle}">
                <Setter Property="FontSize" Value="24" />
            </Style>

            <Style x:Key="ShellSkeletonBlockStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellSkeletonBrush}" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Height" Value="14" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="ShellListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="MinHeight" Value="42" />
            </Style>

            <Style x:Key="ShellListViewStyle" TargetType="ListView">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="SelectionMode" Value="None" />
                <Setter Property="IsItemClickEnabled" Value="False" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource ShellListViewItemStyle}" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            </Style>

            <!-- ================================================================
                 CRITICAL: Override WinUI 3 Fluent theme brushes so every
                 unstyled control inherits the Tron palette. Without these,
                 NavigationView items / Button / CheckBox / ComboBoxItem /
                 ToggleSwitch all render with the Fluent default (light text
                 on white, near-invisible dark text on dark). The operator
                 reported "labeling text is so dark it cannot be seen" —
                 that was the root cause.
                 ================================================================ -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#F0FFFF" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#C8E8F0" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#9ECCDA" />
            <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#5A8590" />
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#F0020A14" />
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#F0040E18" />
            <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="#F0051220" />
            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#7700FFFF" />
            <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="#5500FFFF" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#00FFFF" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#00E8E8" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#00FFFF" />

            <!-- ================================================================
                 WinUI 3 ButtonForeground / Background / Border theme resource
                 overrides for ALL visual states. Without these, the Button
                 ControlTemplate's PointerOver and Pressed states reapply
                 Fluent defaults (dark text on light background).
                 ================================================================ -->
            <SolidColorBrush x:Key="ButtonForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#C0E8F0" />
            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#5A8590" />
            <SolidColorBrush x:Key="ButtonBackground" Color="#F0040E18" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F0081828" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#F0061420" />
            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#F0020810" />
            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#9900E8FF" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#CC00F6FF" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#7700DFEF" />
            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#3300AACC" />

            <!-- ToggleButton visual state overrides -->
            <SolidColorBrush x:Key="ToggleButtonForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#C0E8F0" />
            <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#00FFFF" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#7DFFFF" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#00CCCC" />
            <SolidColorBrush x:Key="ToggleButtonBackground" Color="#F0040E18" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#F0081828" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#F0061420" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#2200FFFF" />

            <!-- ComboBox overrides — the dropdown popup and items render
                 with Fluent defaults unless these are set. -->
            <SolidColorBrush x:Key="ComboBoxForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="#C0E8F0" />
            <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="#5A8590" />
            <SolidColorBrush x:Key="ComboBoxBackground" Color="#F0020A14" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#F0081828" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#F0061420" />
            <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#6600FFFF" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#9900F6FF" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#F0040E18" />
            <SolidColorBrush x:Key="ComboBoxDropDownForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#00FFFF" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="#7DFFFF" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackgroundPointerOver" Color="#F0061420" />

            <!-- TextBox overrides for focused/hover states -->
            <SolidColorBrush x:Key="TextBoxForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="TextBoxForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxForegroundFocused" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxBackground" Color="#F0020A14" />
            <SolidColorBrush x:Key="TextBoxBackgroundPointerOver" Color="#F0061420" />
            <SolidColorBrush x:Key="TextBoxBackgroundFocused" Color="#F0061420" />
            <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#6600FFFF" />
            <SolidColorBrush x:Key="TextBoxBorderBrushPointerOver" Color="#9900F6FF" />
            <SolidColorBrush x:Key="TextBoxBorderBrushFocused" Color="#CC00F6FF" />
            <SolidColorBrush x:Key="TextBoxPlaceholderForeground" Color="#7BA4B0" />

            <!-- ToggleSwitch overrides -->
            <SolidColorBrush x:Key="ToggleSwitchContentForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ToggleSwitchHeaderForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#00CCDD" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#00FFFF" />
            <SolidColorBrush x:Key="ToggleSwitchFillOff" Color="#F0040E18" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#00FFFF" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOff" Color="#6600FFFF" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#000A12" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="#9ECCDA" />

            <!-- ListView / NavigationView item overrides -->
            <SolidColorBrush x:Key="ListViewItemForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ListViewItemForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="#00FFFF" />
            <SolidColorBrush x:Key="NavigationViewItemForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#00FFFF" />
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />

            <!-- Flyout / MenuFlyout / popup overrides -->
            <SolidColorBrush x:Key="FlyoutPresenterBackground" Color="#F0040E18" />
            <SolidColorBrush x:Key="FlyoutBorderThemeBrush" Color="#6600FFFF" />
            <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="#F0040E18" />
            <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="#6600FFFF" />
            <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackground" Color="Transparent" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver" Color="#F0081828" />

            <!-- ContentDialog overrides (for settings, warnings) -->
            <SolidColorBrush x:Key="ContentDialogBackground" Color="#F0040E18" />
            <SolidColorBrush x:Key="ContentDialogForeground" Color="#F0FFFF" />
            <SolidColorBrush x:Key="ContentDialogBorderBrush" Color="#8800FFFF" />
            <SolidColorBrush x:Key="ContentDialogTopOverlay" Color="Transparent" />

            <!-- ScrollBar/ScrollViewer overrides -->
            <SolidColorBrush x:Key="ScrollBarThumbFill" Color="#4400FFFF" />
            <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="#6600FFFF" />
            <SolidColorBrush x:Key="ScrollBarTrackFill" Color="Transparent" />

            <!-- ProgressBar overrides -->
            <SolidColorBrush x:Key="ProgressBarForeground" Color="#00FFFF" />
            <SolidColorBrush x:Key="ProgressBarBackground" Color="#22FFFFFF" />

            <!-- Implicit default for ALL TextBlocks — without this, any
                 TextBlock that doesn't pass an explicit Style renders with
                 the Fluent default foreground which is invisible on our
                 near-black background. -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- Implicit default for ALL Buttons — matches the named
                 ShellCommandButtonStyle so plain <Button> and styled
                 buttons render at identical heights/paddings. Any
                 ad-hoc button in the tree picks up this style unless
                 it explicitly overrides. -->
            <Style TargetType="Button">
                <Setter Property="Background" Value="#F0040E18" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="CharacterSpacing" Value="40" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="MinHeight" Value="48" />
                <!-- Tron-themed focus indicator for keyboard navigation. -->
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="FocusVisualPrimaryBrush" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FocusVisualPrimaryThickness" Value="2" />
                <Setter Property="FocusVisualSecondaryBrush" Value="{StaticResource ShellGlowBrush}" />
                <Setter Property="FocusVisualSecondaryThickness" Value="1" />
                <Setter Property="FocusVisualMargin" Value="-2" />
            </Style>

            <Style TargetType="ToggleSwitch">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="OnContent" Value="ON" />
                <Setter Property="OffContent" Value="OFF" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="FocusVisualPrimaryBrush" Value="{StaticResource ShellAccentBrush}" />
                <Setter Property="FocusVisualPrimaryThickness" Value="2" />
                <Setter Property="FocusVisualSecondaryBrush" Value="{StaticResource ShellGlowBrush}" />
                <Setter Property="FocusVisualSecondaryThickness" Value="1" />
                <Setter Property="FocusVisualMargin" Value="-2" />
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            </Style>

            <Style TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            </Style>

            <Style TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <Style TargetType="ListViewItem">
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="8,6" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="#F0020A14" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellTileEdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="FocusVisualPrimaryBrush" Value="{StaticResource ShellAccentBrush}" />
