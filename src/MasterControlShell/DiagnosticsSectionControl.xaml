<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.DiagnosticsSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <!-- v0.11.0-alpha.3 (PHASE-14 Slice C): operator surface for the
         centralized Diagnostics Service. Mirrors the sibling section
         layout grammar (ShellHeroCardStyle hero + ShellCardStyle decks,
         zero corner radius, shared Tron text styles). The event roster
         is built imperatively in DiagnosticsSectionControl::
         PopulateEventRows (same severity-dot row pattern as the
         Overview Error Reporting card) because rows need per-severity
         colored indicators that a static ItemTemplate cannot express
         without converters. -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource ShellHeroCardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <TextBlock Text="CENTRALIZED EVENT AGGREGATE" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Diagnostics" Style="{StaticResource ShellHeroTitleTextStyle}" />
                        <TextBlock Style="{StaticResource ShellBodyTextStyle}" Text="Query every error, warning, and notable event the orchestration service records, then export a portable Markdown or JSON snapshot for off-host triage." />
                        <TextBlock x:Name="DiagnosticsSummaryText" Style="{StaticResource ShellLabelTextStyle}" Text="Waiting for the first diagnostics summary from the local admin API." />
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="PERSISTENT STORE" Style="{StaticResource ShellEyebrowTextStyle}" />
                                <Border x:Name="DiagnosticsStoreStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                            </StackPanel>
                            <TextBlock x:Name="DiagnosticsTotalEventsText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                            <TextBlock x:Name="DiagnosticsStoreStatusText" Style="{StaticResource ShellDataTextStyle}" TextWrapping="Wrap" Text="Store posture pending." />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Event Query" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock Text="Filter the central aggregate by severity and source subsystem, refresh on demand, export the full history, or clear the store after triage." Style="{StaticResource ShellBodyTextStyle}" />

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Severity" Style="{StaticResource ShellLabelTextStyle}" />
                            <ComboBox x:Name="SeverityFilterSelector" SelectionChanged="SeverityFilterSelector_SelectionChanged" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="All severities" Tag="" />
                                <ComboBoxItem Content="Debug" Tag="debug" />
                                <ComboBoxItem Content="Info" Tag="info" />
                                <ComboBoxItem Content="Warning" Tag="warning" />
                                <ComboBoxItem Content="Error" Tag="error" />
                                <ComboBoxItem Content="Critical" Tag="critical" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Source" Style="{StaticResource ShellLabelTextStyle}" />
                            <ComboBox x:Name="SourceFilterSelector" SelectionChanged="SourceFilterSelector_SelectionChanged" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="All sources" Tag="" />
                                <ComboBoxItem Content="Runtime" Tag="runtime" />
                                <ComboBoxItem Content="Supervisor" Tag="supervisor" />
                                <ComboBoxItem Content="Installer" Tag="installer" />
                                <ComboBoxItem Content="Self-Test" Tag="self-test" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="RefreshDiagnosticsButton" Click="RefreshDiagnosticsButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Refresh" />
                        <Button x:Name="ExportMarkdownButton" Click="ExportMarkdownButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Export Markdown" />
                        <Button x:Name="ExportJsonButton" Click="ExportJsonButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Export JSON" />
                        <Button x:Name="ClearDiagnosticsButton" Click="ClearDiagnosticsButton_Click" Style="{StaticResource ShellSecondaryButtonStyle}" Content="Clear" />
                    </StackPanel>

                    <TextBlock x:Name="DiagnosticsStatusText" Style="{StaticResource ShellDataTextStyle}" TextWrapping="Wrap" Text="Diagnostics are aggregated by the local admin API from every orchestration subsystem." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Diagnostic Events" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="DiagnosticsEventsHeadlineText" Style="{StaticResource ShellLabelTextStyle}" Text="Loading diagnostic events..." />
                    <ScrollViewer MaxHeight="640" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DiagnosticsEventsStack" Spacing="0" />
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
