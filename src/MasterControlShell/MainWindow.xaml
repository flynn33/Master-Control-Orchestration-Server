<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MasterControlShell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MasterControlShell"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Master Control Orchestration Server">
    <Grid x:Name="RootGrid" Background="{StaticResource ShellBackgroundBrush}" Loaded="RootGrid_Loaded">
        <Grid>
            <Rectangle Fill="{StaticResource ShellBackgroundBrush}" />

            <Canvas IsHitTestVisible="False" Opacity="0.55">
                <Ellipse Width="920" Height="920" Canvas.Left="-260" Canvas.Top="-320" Stroke="{StaticResource ShellAccentSoftBrush}" StrokeThickness="2" />
                <Ellipse Width="560" Height="560" Canvas.Left="1010" Canvas.Top="-120" Stroke="{StaticResource ShellGlowBrush}" StrokeThickness="2" />
                <Rectangle Width="820" Height="1" Canvas.Left="92" Canvas.Top="188" Fill="{StaticResource ShellGridlineBrush}" />
                <Rectangle Width="1" Height="980" Canvas.Left="134" Canvas.Top="120" Fill="{StaticResource ShellGridlineBrush}" />
            </Canvas>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="TitleBarHost" Padding="22,18" Background="#2400F6FF" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="24">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="TitleBarLeftInsetColumn" Width="0" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition x:Name="TitleBarRightInsetColumn" Width="0" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                            <Border Width="52" Height="52" Background="#1800F6FF" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="18">
                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" Foreground="{StaticResource ShellAccentBrush}" Glyph="&#xE7F4;" />
                            </Border>

                            <StackPanel Spacing="4">
                                <TextBlock Text="MASTER CONTROL ORCHESTRATION SERVER" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock Text="Windows command shell for guided setup, telemetry, MCP orchestration, provider routing, governance, and runtime control." Style="{StaticResource ShellLabelTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Border x:Name="ApiBadgeBorder" Padding="12,6" Background="#2200F6FF" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="999">
                                <TextBlock x:Name="ApiBadgeText" Text="API UNKNOWN" Style="{StaticResource ShellEyebrowTextStyle}" />
                            </Border>
                            <Border x:Name="ServiceBadgeBorder" Padding="12,6" Background="#2200F6FF" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="999">
                                <TextBlock x:Name="ServiceBadgeText" Text="SERVICE UNKNOWN" Style="{StaticResource ShellEyebrowTextStyle}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="StatusBannerBorder" Grid.Row="1" Margin="0,18,0,0" Padding="18,14" Background="#1A103045" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="18">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StatusBannerStateText" Text="SYSTEM STATUS" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock x:Name="StatusBannerText" Grid.Column="1" Style="{StaticResource ShellBodyTextStyle}" Text="Loading local service and dashboard state." VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Margin="0,22,0,0" Background="#96060E15" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="28">
                    <NavigationView
                        x:Name="ShellNavigation"
                        Background="Transparent"
                        CompactPaneLength="64"
                        IsBackButtonVisible="Collapsed"
                        IsPaneOpen="True"
                        IsSettingsVisible="False"
                        OpenPaneLength="252"
                        PaneTitle="GRID INDEX"
                        SelectionChanged="ShellNavigation_SelectionChanged">
                        <Grid Margin="20,16,20,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource ShellHeroCardStyle}">
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.3*" />
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="12">
                                        <TextBlock x:Name="CurrentViewEyebrowText" Text="OVERVIEW" Style="{StaticResource ShellEyebrowTextStyle}" />
                                        <TextBlock x:Name="CurrentViewTitleText" Text="Command Deck" Style="{StaticResource ShellHeroTitleTextStyle}" />
                                        <TextBlock x:Name="CurrentViewDescriptionText" MaxWidth="560" Style="{StaticResource ShellBodyTextStyle}" Text="Navigate operational surfaces for telemetry, runtime orchestration, provider routing, and secure configuration." />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="16">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="FORSETTI SURFACE TOOLBAR" Style="{StaticResource ShellEyebrowTextStyle}" />
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                                <StackPanel x:Name="ForsettiToolbarHost" Orientation="Horizontal" Spacing="12" />
                                            </ScrollViewer>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="HOST CONTROLS" Style="{StaticResource ShellEyebrowTextStyle}" />
                                            <Grid ColumnSpacing="12" RowSpacing="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button x:Name="RefreshButton" Click="RefreshButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Refresh" />
                                                <Button x:Name="StartServiceButton" Grid.Column="1" Click="StartServiceButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Start Service" />
                                                <Button x:Name="StopServiceButton" Grid.Column="2" Click="StopServiceButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Stop Service" />
                                                <Button x:Name="OpenDashboardButton" Grid.Row="1" Click="OpenDashboardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Dashboard" />
                                                <Button x:Name="OpenConfigButton" Grid.Row="1" Grid.Column="1" Click="OpenConfigButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Config" />
                                                <Button x:Name="OpenDataButton" Grid.Row="1" Grid.Column="2" Click="OpenDataButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Data" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="GUIDED SETUP WIZARDS" Style="{StaticResource ShellEyebrowTextStyle}" />
                                            <Grid ColumnSpacing="12" RowSpacing="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button x:Name="GuidedProviderWizardButton" Click="GuidedProviderWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Connect AI Model" />
                                                <Button x:Name="GuidedMcpWizardButton" Grid.Column="1" Click="GuidedMcpWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New MCP Server" />
                                                <Button x:Name="GuidedSubAgentWizardButton" Grid.Column="2" Click="GuidedSubAgentWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent" />
                                                <Button x:Name="GuidedSubAgentGroupWizardButton" Grid.Row="1" Click="GuidedSubAgentGroupWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent Group" />
                                                <Button x:Name="GuidedAppleHostWizardButton" Grid.Row="1" Grid.Column="1" Click="GuidedAppleHostWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Apple Host" />
                                                <Button x:Name="GuidedProviderAssignmentWizardButton" Grid.Row="1" Grid.Column="2" Click="GuidedProviderAssignmentWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Assign Responsibility" />
                                                <Button x:Name="GuidedForsettiModuleWizardButton" Grid.Row="2" Click="GuidedForsettiModuleWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Manage Forsetti Modules" />
                                                <Button x:Name="GuidedImportWizardButton" Grid.Row="2" Grid.Column="1" Click="GuidedImportWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Guided Import" />
                                                <Button x:Name="GuidedSecurityWizardButton" Grid.Row="2" Grid.Column="2" Click="GuidedSecurityWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Security Hardening" />
                                                <Button x:Name="GuidedSettingsWizardButton" Grid.Row="3" Click="GuidedSettingsWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Host Settings" />
                                                <Button x:Name="GuidedProviderExecutionWizardButton" Grid.Row="3" Grid.Column="1" Click="GuidedProviderExecutionWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Validate Provider Routing" />
                                                <Button x:Name="GuidedRuntimeMaintenanceWizardButton" Grid.Row="3" Grid.Column="2" Click="GuidedRuntimeMaintenanceWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Manage Runtime Lanes" />

                                                <Border Grid.Row="4" Grid.ColumnSpan="3" Padding="12,10" Background="#1200F6FF" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="14">
                                                    <TextBlock
                                                        x:Name="GuidedWorkflowStatusText"
                                                        Style="{StaticResource ShellLabelTextStyle}"
                                                        Text="Use guided setup to connect models, assign orchestration responsibilities, validate provider routing, deploy and maintain runtime lanes, harden security, shape host settings, and manage Forsetti modules without digging through raw admin forms."
                                                        TextWrapping="WrapWholeWords" />
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Column="2" Padding="10" Background="#1200F6FF" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="22">
                                        <Grid Width="232" Height="232" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse Stroke="#1800F6FF" StrokeThickness="2" />
                                            <Ellipse Width="188" Height="188" Stroke="#3200F6FF" StrokeThickness="2" />
                                            <Ellipse Width="140" Height="140" Stroke="#5000F6FF" StrokeThickness="2" />
                                            <Ellipse Width="88" Height="88" Fill="#1800F6FF" Stroke="{StaticResource ShellAccentBrush}" StrokeThickness="2" />
                                            <Rectangle Width="2" Height="232" Fill="{StaticResource ShellGridlineBrush}" HorizontalAlignment="Center" />
                                            <Rectangle Width="232" Height="2" Fill="{StaticResource ShellGridlineBrush}" VerticalAlignment="Center" />

                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                                <TextBlock Text="GRID PULSE" HorizontalAlignment="Center" Style="{StaticResource ShellEyebrowTextStyle}" />
                                                <TextBlock x:Name="PulseStateText" HorizontalAlignment="Center" Style="{StaticResource ShellStatusTextStyle}" Text="SYNC" />
                                                <TextBlock x:Name="PulseCaptionText" HorizontalAlignment="Center" Style="{StaticResource ShellLabelTextStyle}" Text="Awaiting runtime telemetry." />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,18,0,0" ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource ShellMetricTileStyle}"><StackPanel Spacing="6"><TextBlock Text="SERVICE" Style="{StaticResource ShellLabelTextStyle}" /><TextBlock x:Name="ServiceStateText" Style="{StaticResource ShellValueTextStyle}" Text="Unknown" /></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}"><StackPanel Spacing="6"><TextBlock Text="ADMIN API" Style="{StaticResource ShellLabelTextStyle}" /><TextBlock x:Name="ApiStateText" Style="{StaticResource ShellValueTextStyle}" Text="Unknown" /></StackPanel></Border>
                                <Border Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}"><StackPanel Spacing="6"><TextBlock Text="RUNTIME LANES" Style="{StaticResource ShellLabelTextStyle}" /><TextBlock x:Name="EndpointCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" /></StackPanel></Border>
                                <Border Grid.Column="3" Style="{StaticResource ShellMetricTileStyle}"><StackPanel Spacing="6"><TextBlock Text="PROVIDERS" Style="{StaticResource ShellLabelTextStyle}" /><TextBlock x:Name="ProviderCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" /></StackPanel></Border>
                            </Grid>

                            <Border Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource ShellCardStyle}">
                                <ContentPresenter x:Name="SectionContentHost" />
                            </Border>
                        </Grid>
                    </NavigationView>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
