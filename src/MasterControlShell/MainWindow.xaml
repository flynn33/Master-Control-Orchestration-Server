<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MasterControlShell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MasterControlShell"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Master Control Orchestration Server">
    <Grid x:Name="RootGrid" Background="{StaticResource ShellBackgroundBrush}" RequestedTheme="Dark" Loaded="RootGrid_Loaded">
        <Grid>
            <Rectangle Fill="{StaticResource ShellBackgroundBrush}" />

            <Canvas IsHitTestVisible="False" Opacity="0.55">
                <Ellipse Width="920" Height="920" Canvas.Left="-260" Canvas.Top="-320" Stroke="{StaticResource ShellAccentSoftBrush}" StrokeThickness="2" />
                <Ellipse Width="560" Height="560" Canvas.Left="1010" Canvas.Top="-120" Stroke="{StaticResource ShellGlowBrush}" StrokeThickness="2" />
                <Rectangle Width="820" Height="1" Canvas.Left="92" Canvas.Top="188" Fill="{StaticResource ShellGridlineBrush}" />
                <Rectangle Width="1" Height="980" Canvas.Left="134" Canvas.Top="120" Fill="{StaticResource ShellGridlineBrush}" />
            </Canvas>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="TitleBarHost" Padding="16,12" Background="#1400DFFF" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="0">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="TitleBarLeftInsetColumn" Width="0" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition x:Name="TitleBarRightInsetColumn" Width="0" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                            <Border Width="44" Height="44" Background="#1200DFFF" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="0">
                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" Foreground="{StaticResource ShellAccentBrush}" Glyph="&#xE7F4;" />
                            </Border>

                            <StackPanel Spacing="4">
                                <TextBlock Text="MASTER CONTROL ORCHESTRATION SERVER" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock Text="Windows application for guided setup, telemetry, MCP orchestration, governance, and runtime control." Style="{StaticResource ShellLabelTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Border x:Name="LiveTelemetryBadgeBorder" Padding="10,4" Background="#2200DFFF" BorderBrush="{StaticResource ShellAccentBrush}" BorderThickness="1" CornerRadius="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="LiveTelemetryLabelText" Text="LIVE" Style="{StaticResource ShellEyebrowTextStyle}" />
                                    <TextBlock x:Name="LiveTelemetrySampleText" Text="#0" Style="{StaticResource ShellEyebrowTextStyle}" />
                                    <TextBlock x:Name="LiveClockText" Text="--:--:--" Style="{StaticResource ShellLiveClockTextStyle}" />
                                </StackPanel>
                            </Border>
                            <Border x:Name="ApiBadgeBorder" Padding="10,4" Background="#1200DFFF" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="0">
                                <TextBlock x:Name="ApiBadgeText" Text="API UNKNOWN" Style="{StaticResource ShellEyebrowTextStyle}" />
                            </Border>
                            <Border x:Name="ServiceBadgeBorder" Padding="10,4" Background="#1200DFFF" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="0">
                                <TextBlock x:Name="ServiceBadgeText" Text="SERVICE UNKNOWN" Style="{StaticResource ShellEyebrowTextStyle}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="StatusBannerBorder" Grid.Row="1" Margin="0,12,0,0" Padding="14,10" Background="#120B1620" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="0">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StatusBannerStateText" Text="SYSTEM STATUS" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock x:Name="StatusBannerText" Grid.Column="1" Style="{StaticResource ShellBodyTextStyle}" Text="Loading local service and dashboard state." VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Margin="0,14,0,0" Background="#AA04090E" BorderBrush="{StaticResource ShellCardEdgeBrush}" BorderThickness="1" CornerRadius="0">
                    <!-- NavigationView kept as a chromeless content host so existing
                         .cpp references (ShellNavigation, ShellNavigation_SelectionChanged,
                         MenuItems, SelectedItem) still compile. The entire pane is
                         collapsed to 0 px and the toggle button is hidden so no blank
                         left column is rendered. Navigation happens through the
                         ForsettiToolbarHost buttons in the hero card and the GUIDED
                         SETUP WIZARDS grid. -->
                    <NavigationView
                        x:Name="ShellNavigation"
                        Background="Transparent"
                        IsBackButtonVisible="Collapsed"
                        IsPaneOpen="True"
                        IsPaneToggleButtonVisible="False"
                        IsSettingsVisible="False"
                        IsTitleBarAutoPaddingEnabled="False"
                        PaneDisplayMode="Top"
                        PaneTitle=""
                        SelectionChanged="ShellNavigation_SelectionChanged">
                        <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled" VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                        <Grid Margin="14,12,14,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />   <!-- 0: hero card -->
                                <RowDefinition Height="Auto" />   <!-- 1: 4-metric summary -->
                                <RowDefinition Height="Auto" />   <!-- 2: live command stream -->
                                <RowDefinition Height="Auto" />   <!-- 3: section content + sub-agent footer -->
                            </Grid.RowDefinitions>

                            <Border x:Name="HeroCardHost" Style="{StaticResource ShellHeroCardStyle}">
                                <Grid ColumnSpacing="20">
                                    <!-- Symmetric 3-column layout: equal widths for
                                         Telemetry / Controls / Live Operations so the
                                         hero card reads as a tidy tri-panel command
                                         deck rather than a lopsided 1.55/1.05/0.9. -->
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="14">
                                        <TextBlock x:Name="CurrentViewEyebrowText" Text="OVERVIEW" Style="{StaticResource ShellEyebrowTextStyle}" />
                                        <TextBlock x:Name="CurrentViewTitleText" Text="Command Deck" Style="{StaticResource ShellHeroTitleTextStyle}" />
                                        <TextBlock x:Name="CurrentViewDescriptionText" MaxWidth="560" Style="{StaticResource ShellBodyTextStyle}" Text="Navigate operational surfaces for telemetry, runtime orchestration, and secure configuration." />

                                        <Border Background="#1000DFFF" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="0" Padding="10,8">
                                            <StackPanel Spacing="12">
                                                <TextBlock Text="ALWAYS-ON COMMAND TELEMETRY" Style="{StaticResource ShellEyebrowTextStyle}" />
                                                <Grid ColumnSpacing="12" RowSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Border Style="{StaticResource ShellMetricTileStyle}">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="CPU LOAD" Style="{StaticResource ShellLabelTextStyle}" />
                                                            <TextBlock x:Name="HeroCpuValueText" Style="{StaticResource ShellValueTextStyle}" Text="0%" />
                                                            <ProgressBar x:Name="HeroCpuProgressBar" Height="6" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="MEMORY" Style="{StaticResource ShellLabelTextStyle}" />
                                                            <TextBlock x:Name="HeroMemoryValueText" Style="{StaticResource ShellValueTextStyle}" Text="0%" />
                                                            <ProgressBar x:Name="HeroMemoryProgressBar" Height="6" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="1" Style="{StaticResource ShellMetricTileStyle}">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="DISK" Style="{StaticResource ShellLabelTextStyle}" />
                                                            <TextBlock x:Name="HeroDiskValueText" Style="{StaticResource ShellValueTextStyle}" Text="0%" />
                                                            <ProgressBar x:Name="HeroDiskProgressBar" Height="6" Maximum="100" Foreground="{StaticResource ShellAccentBrush}" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="LIVE TRAFFIC" Style="{StaticResource ShellLabelTextStyle}" />
                                                            <TextBlock x:Name="HeroTrafficValueText" Style="{StaticResource ShellValueTextStyle}" Text="0 B/s" />
                                                            <TextBlock x:Name="HeroTrafficDetailText" Style="{StaticResource ShellLabelTextStyle}" Text="Awaiting telemetry." TextWrapping="WrapWholeWords" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <TextBlock x:Name="HeroTelemetrySummaryText" Style="{StaticResource ShellLabelTextStyle}" Text="Waiting for a live orchestration snapshot." TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="16">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="QUICK ACTIONS" Style="{StaticResource ShellEyebrowTextStyle}" />
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                                <StackPanel x:Name="ForsettiToolbarHost" Orientation="Horizontal" Spacing="12" />
                                            </ScrollViewer>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="HOST CONTROLS" Style="{StaticResource ShellEyebrowTextStyle}" />
                                            <Grid ColumnSpacing="12" RowSpacing="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button x:Name="RefreshButton" Click="RefreshButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Refresh" />
                                                <Button x:Name="StartServiceButton" Grid.Column="1" Click="StartServiceButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Start Service" />
                                                <Button x:Name="StopServiceButton" Grid.Row="1" Click="StopServiceButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Stop Service" />
                                                <Button x:Name="OpenDashboardButton" Grid.Row="1" Grid.Column="1" Click="OpenDashboardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Dashboard" />
                                                <Button x:Name="OpenConfigButton" Grid.Row="2" Click="OpenConfigButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Config" />
                                                <Button x:Name="OpenDataButton" Grid.Row="2" Grid.Column="1" Click="OpenDataButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Open Data" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="GUIDED SETUP WIZARDS" Style="{StaticResource ShellEyebrowTextStyle}" />
                                            <Grid ColumnSpacing="12" RowSpacing="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button x:Name="GuidedMcpWizardButton" Click="GuidedMcpWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New MCP Server" />
                                                <Button x:Name="GuidedRuntimeMaintenanceWizardButton" Grid.Column="1" Click="GuidedRuntimeMaintenanceWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Manage Runtime Lanes" />
                                                <Button x:Name="GuidedSubAgentWizardButton" Grid.Row="1" Click="GuidedSubAgentWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent" />
                                                <Button x:Name="GuidedSubAgentGroupWizardButton" Grid.Row="1" Grid.Column="1" Click="GuidedSubAgentGroupWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Sub-Agent Group" />
                                                <Button x:Name="GuidedAppleHostWizardButton" Grid.Row="2" Click="GuidedAppleHostWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Apple Host" />
                                                <Button x:Name="GuidedForsettiModuleWizardButton" Grid.Row="2" Grid.Column="1" Click="GuidedForsettiModuleWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Manage Forsetti Modules" />
                                                <Button x:Name="GuidedImportWizardButton" Grid.Row="3" Click="GuidedImportWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Guided Import" />
                                                <Button x:Name="GuidedSecurityWizardButton" Grid.Row="3" Grid.Column="1" Click="GuidedSecurityWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Security Hardening" />
                                                <Button x:Name="GuidedSettingsWizardButton" Grid.Row="4" Grid.ColumnSpan="2" Click="GuidedSettingsWizardButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Host Settings" />

                                                <Border Grid.Row="5" Grid.ColumnSpan="2" Padding="10,8" Background="#1000DFFF" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="0">
                                                    <TextBlock
                                                        x:Name="GuidedWorkflowStatusText"
                                                        Style="{StaticResource ShellLabelTextStyle}"
                                                        Text="Use guided setup to deploy and maintain runtime lanes, harden security, shape host settings, and manage Forsetti modules without digging through raw admin forms."
                                                        TextWrapping="WrapWholeWords" />
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Column="2" Style="{StaticResource ShellCardStyle}">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="LIVE OPERATIONS" Style="{StaticResource ShellEyebrowTextStyle}" />
                                            <TextBlock x:Name="HeroOperationsHeadlineText" Style="{StaticResource ShellStatusTextStyle}" Text="STANDBY" />
                                            <TextBlock x:Name="HeroOperationsBodyText" Style="{StaticResource ShellBodyTextStyle}" Text="Waiting for a live orchestration snapshot." TextWrapping="WrapWholeWords" />

                                            <Border Style="{StaticResource ShellMetricTileStyle}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="HOST IDENTITY" Style="{StaticResource ShellLabelTextStyle}" />
                                                    <TextBlock x:Name="HeroIdentityText" Style="{StaticResource ShellDataTextStyle}" Text="Awaiting host identity." />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource ShellMetricTileStyle}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="GOVERNANCE POSTURE" Style="{StaticResource ShellLabelTextStyle}" />
                                                    <TextBlock x:Name="HeroGovernanceText" Style="{StaticResource ShellDataTextStyle}" Text="Awaiting CLU and governance posture." />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource ShellMetricTileStyle}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="RUNTIME LEDGER" Style="{StaticResource ShellLabelTextStyle}" />
                                                    <TextBlock x:Name="HeroRuntimeLedgerText" Style="{StaticResource ShellDataTextStyle}" Text="Awaiting runtime inventory." />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,18,0,0" ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource ShellMetricTileStyle}"><StackPanel Spacing="6"><TextBlock Text="SERVICE" Style="{StaticResource ShellLabelTextStyle}" /><TextBlock x:Name="ServiceStateText" Style="{StaticResource ShellValueTextStyle}" Text="Unknown" /></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource ShellMetricTileStyle}"><StackPanel Spacing="6"><TextBlock Text="ADMIN API" Style="{StaticResource ShellLabelTextStyle}" /><TextBlock x:Name="ApiStateText" Style="{StaticResource ShellValueTextStyle}" Text="Unknown" /></StackPanel></Border>
                                <Border Grid.Column="2" Style="{StaticResource ShellMetricTileStyle}"><StackPanel Spacing="6"><TextBlock Text="RUNTIME LANES" Style="{StaticResource ShellLabelTextStyle}" /><TextBlock x:Name="EndpointCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" /></StackPanel></Border>
                            </Grid>

                            <!-- LIVE COMMAND/REQUEST STREAM
                                 Always-visible scrolling log of every admin API request,
                                 governance decision, and lifecycle event flowing through
                                 the service host. Populated by RefreshActivityStreamAsync
                                 polling /api/activity?since={id} on a one-second cadence. -->
                            <Border Grid.Row="2" Margin="0,14,0,0" Style="{StaticResource ShellCardStyle}" BorderBrush="{StaticResource ShellAccentBrush}">
                                <Grid RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="14">
                                        <TextBlock Text="LIVE COMMAND STREAM" Style="{StaticResource ShellEyebrowTextStyle}" />
                                        <Border Background="{StaticResource ShellAccentSoftBrush}" BorderBrush="{StaticResource ShellAccentBrush}" BorderThickness="1" CornerRadius="0" Padding="8,2">
                                            <TextBlock x:Name="ActivityStreamCounterText" Text="0 events" Style="{StaticResource ShellSubAgentBadgeSubtitleStyle}" />
                                        </Border>
                                        <TextBlock x:Name="ActivityStreamStatusText" Text="Polling /api/activity..." Style="{StaticResource ShellDataTextStyle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ListView x:Name="ActivityStreamListView"
                                              Grid.Row="1"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              SelectionMode="None"
                                              MaxHeight="220"
                                              IsItemClickEnabled="False">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding" Value="4,3" />
                                                <Setter Property="MinHeight" Value="22" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>
                                </Grid>
                            </Border>

                            <Border Grid.Row="3" Margin="0,18,0,0" Style="{StaticResource ShellCardStyle}">
                                <Grid RowSpacing="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ContentPresenter Grid.Row="0" x:Name="SectionContentHost" />

                                    <!-- Sub-agents footer pill row: Tron command-center motif.
                                         v0.7.8: badges are now built imperatively from
                                         ShellSnapshot.subAgentRuntimeStats so each shows
                                         real telemetry (utilization bar + active-client IPs)
                                         instead of static stub names. SubAgentFooterGrid is
                                         a single-row Grid populated by
                                         MainWindow::ApplySubAgentFooter on every snapshot. -->
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" x:Name="SubAgentFooterHeadline" Text="SUB-AGENT GRID" Style="{StaticResource ShellEyebrowTextStyle}" Margin="0,0,0,8" />
                                        <Grid Grid.Row="1" x:Name="SubAgentFooterGrid" ColumnSpacing="10" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                        </ScrollViewer>
                    </NavigationView>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
