<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.OverviewSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel Spacing="20">

            <!-- Hero header -->
            <Border Style="{StaticResource ShellHeroCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="MASTER CONTROL · OVERVIEW" Style="{StaticResource ShellEyebrowTextStyle}" />
                    <TextBlock Text="Operational Summary" Style="{StaticResource ShellHeroTitleTextStyle}" />
                    <TextBlock
                        Style="{StaticResource ShellBodyTextStyle}"
                        Foreground="{StaticResource ShellTextMutedBrush}"
                        Text="High-signal state of the orchestration control plane. Drill into Telemetry, Runtime, or CLU for details." />
                    <Border Style="{StaticResource ShellStatusChipStyle}" Margin="0,6,0,0">
                        <TextBlock x:Name="OverviewStatusText"
                                   Style="{StaticResource ShellStatusChipTextStyle}"
                                   Text="WAITING FOR LOCAL SERVICE SYNCHRONIZATION" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- v0.9.99: SELF-TESTS + ERROR REPORTING side-by-side row
                 immediately under the hero header. Operator directive:
                 self tests must be VISIBLE on startup and failures must
                 land in the Overview Error Frame. Pre-v0.9.99 both cards
                 existed but lived below the Claude Code Control + the
                 operational narratives + the 2x2 status grid; the
                 operator had to scroll past five sections to find them.
                 v0.9.99 lifts them to the position right under the hero
                 so they're the first thing visible on the Overview tab,
                 every time the shell boots. Two-column layout puts the
                 two cards side-by-side so neither hides the other. -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- v0.9.75: VISIBLE self-test card.
                     v0.9.99: lifted to the top of Overview so it is the
                     first signal the operator sees on startup. -->
                <Border Style="{StaticResource ShellCardStyle}" BorderBrush="{StaticResource ShellAccentBrush}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="SELF-TESTS" Style="{StaticResource ShellEyebrowTextStyle}" />
                                    <Border x:Name="SelfTestStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                                </StackPanel>
                                <TextBlock x:Name="SelfTestHeadline"
                                           Text="Self-tests pending..." Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock x:Name="SelfTestSubline"
                                           Style="{StaticResource ShellLabelTextStyle}"
                                           Foreground="{StaticResource ShellTextMutedBrush}"
                                           Text="Boot-time probes against admin / gateway / every supervised pool / telemetry / on-disk workers." />
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="ReRunSelfTestsButton" Click="ReRunSelfTestsButton_Click" Content="Re-run" Style="{StaticResource ShellCommandButtonStyle}" VerticalAlignment="Top" />
                        </Grid>
                        <ScrollViewer MaxHeight="280" VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="SelfTestList" Spacing="4" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- v0.8.7 Error Reporting frame.
                     v0.9.99: lifted alongside Self-Tests so failures are
                     the second signal the operator sees on startup. -->
                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}" BorderBrush="{StaticResource ShellAccentBrush}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="ERROR REPORTING" Style="{StaticResource ShellEyebrowTextStyle}" />
                                    <Border x:Name="ErrorReportingStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF1cf2c1" />
                                </StackPanel>
                                <TextBlock x:Name="ErrorReportingHeadline" Text="No errors recorded" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock
                                    Style="{StaticResource ShellLabelTextStyle}"
                                    Text="HTTP 4xx/5xx events and error-kind activity captured by the local admin API." />
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="ExportErrorsButton" Click="ExportErrorsButton_Click" Content="Export to JSON" Style="{StaticResource ShellCommandButtonStyle}" VerticalAlignment="Top" />
                        </Grid>
                        <TextBlock x:Name="ErrorExportStatusText"
                                   Style="{StaticResource ShellLabelTextStyle}"
                                   Foreground="{StaticResource ShellTextMutedBrush}"
                                   TextWrapping="WrapWholeWords"
                                   Text="" />
                        <ScrollViewer MaxHeight="280" VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ErrorReportingList" Spacing="6" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Claude Code Control toggle. The
                 ToggleSwitch fires Toggled on every state change including
                 programmatic ones, so the .cpp handler suspends the runtime
                 toggle call while a snapshot-driven IsOn update is pending. -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="CLAUDE CODE CONTROL" Style="{StaticResource ShellEyebrowTextStyle}" />
                    <TextBlock Text="Direct AI Plugin Connection" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock
                        Style="{StaticResource ShellBodyTextStyle}"
                        Foreground="{StaticResource ShellTextMutedBrush}"
                        TextWrapping="WrapWholeWords"
                        Text="Toggle on to register the bundled mcos-control plugin into Claude Code for the current Windows user. The runtime drops a directory junction at %USERPROFILE%\.claude\plugins\mcos-control pointing at the bundled plugin source. Restart Claude Code afterwards. Toggle off removes only the junction." />
                    <ToggleSwitch x:Name="ClaudePluginToggle"
                                  Header="Connect Claude Code to this server"
                                  OnContent="Connected"
                                  OffContent="Disconnected"
                                  Toggled="ClaudePluginToggle_Toggled" />
                    <TextBlock x:Name="ClaudePluginStatusText"
                               Style="{StaticResource ShellDataTextStyle}"
                               TextWrapping="WrapWholeWords"
                               Text="Checking plugin registration state..." />
                    <TextBlock x:Name="ClaudePluginDetailText"
                               Style="{StaticResource ShellDataTextStyle}"
                               Foreground="{StaticResource ShellTextMutedBrush}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <!-- Operational summary narrative -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="OPERATIONAL SNAPSHOT" Style="{StaticResource ShellEyebrowTextStyle}" />
                    <TextBlock Text="Live State" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="OverviewTextBlock"
                               Style="{StaticResource ShellBodyTextStyle}"
                               Text="Loading shell snapshot..." />
                </StackPanel>
            </Border>

            <!-- Environment + Configuration narratives -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="HOST &amp; NETWORK" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Environment Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="EnvironmentNarrativeText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Environment details will populate here." />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="RUNTIME CONFIGURATION" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Configuration Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="ConfigurationNarrativeText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Configuration details will populate here." />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- v0.10.10: per operator directive the MCP SERVERS and
                 SUB-AGENTS summary cards were removed from the Overview
                 deck. Those decks live on Runtime and Telemetry as
                 footer-style tile grids; the Overview status grid is
                 now just APIS & SERVICES + SECURITY STANCE (single row).
                 -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="APIS &amp; SERVICES" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <Border x:Name="ApiServicesStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                        </StackPanel>
                        <TextBlock Text="Service + Admin API + Gateway" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="ApiServicesText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Loading service + API status..." />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="SECURITY STANCE" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <Border x:Name="SecurityStanceStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                        </StackPanel>
                        <TextBlock Text="Posture + Governance" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="SecurityStanceText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Loading security stance..." />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- v0.9.76: Supervisor Agent Assignment Wizard card.
                 Operator picks exactly one supervisor model (ChatGPT,
                 Claude, or Grok) and MCOS generates a model-specific
                 supervisor configuration JSON conforming to
                 mcos.supervisor.config.v1. The native FileSavePicker
                 then asks the operator where to save it; the operator
                 moves that file to the LAN client running the chosen
                 model. Status frame mirrors /api/supervisor/status so
                 the card always shows the live state (off / pending
                 connection / connected / revoked / error).
                 Toggle group is single-selection: turning one provider
                 on turns the others off; turning the active one off
                 begins the revocation flow. -->
            <Border Style="{StaticResource ShellCardStyle}" BorderBrush="{StaticResource ShellAccentBrush}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="SUPERVISOR AGENT" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <Border x:Name="SupervisorStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                    </StackPanel>
                    <TextBlock x:Name="SupervisorHeadlineText" Text="No supervisor assigned." Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="SupervisorSublineText"
                               Style="{StaticResource ShellLabelTextStyle}"
                               TextWrapping="Wrap"
                               Text="Choose one AI model to supervise coding agents and make project decisions through MCOS. Generate Config will save a provider-specific JSON to the location you choose; move it to the LAN client running that model and import it there." />
                    <StackPanel Spacing="6">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ChatGPT" Style="{StaticResource ShellDataTextStyle}" />
                                <TextBlock Text="Recommended for design-authority supervision and project-level decision review."
                                           Style="{StaticResource ShellLabelTextStyle}"
                                           Foreground="{StaticResource ShellTextMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" x:Name="SupervisorChatGptToggle"
                                          Tag="chatgpt"
                                          OffContent="" OnContent=""
                                          Toggled="SupervisorChatGptToggle_Toggled" />
                        </Grid>
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Claude" Style="{StaticResource ShellDataTextStyle}" />
                                <TextBlock Text="Recommended for Claude Code coordination and local coding-agent workflows."
                                           Style="{StaticResource ShellLabelTextStyle}"
                                           Foreground="{StaticResource ShellTextMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" x:Name="SupervisorClaudeToggle"
                                          Tag="claude"
                                          OffContent="" OnContent=""
                                          Toggled="SupervisorClaudeToggle_Toggled" />
                        </Grid>
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Grok" Style="{StaticResource ShellDataTextStyle}" />
                                <TextBlock Text="Recommended for alternate review or independent validation."
                                           Style="{StaticResource ShellLabelTextStyle}"
                                           Foreground="{StaticResource ShellTextMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" x:Name="SupervisorGrokToggle"
                                          Tag="grok"
                                          OffContent="" OnContent=""
                                          Toggled="SupervisorGrokToggle_Toggled" />
                        </Grid>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SupervisorGenerateButton"
                                Content="Generate Config &amp; Save..."
                                IsEnabled="False"
                                Click="SupervisorGenerateButton_Click"
                                Style="{StaticResource ShellCommandButtonStyle}" />
                        <Button x:Name="SupervisorRevokeButton"
                                Content="Revoke Active"
                                IsEnabled="False"
                                Click="SupervisorRevokeButton_Click"
                                Style="{StaticResource ShellCommandButtonStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="SupervisorStatusText"
                               Style="{StaticResource ShellLabelTextStyle}"
                               Foreground="{StaticResource ShellTextMutedBrush}"
                               TextWrapping="Wrap"
                               Text="Status: off." />
                    <!-- v0.9.79: assignment / config / expires / heartbeat detail line.
                         Populated by ApplySupervisorCard whenever
                         snapshot.supervisorStatus.assignmentId is set. Stays
                         hidden when there is no active assignment so the
                         off-state card doesn't show empty fields. -->
                    <TextBlock x:Name="SupervisorDetailText"
                               Style="{StaticResource ShellLabelTextStyle}"
                               Foreground="{StaticResource ShellTextMutedBrush}"
                               FontFamily="Consolas, Cascadia Mono, Courier New"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Text="" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
