<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.OverviewSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel Spacing="20">

            <!-- Hero header -->
            <Border Style="{StaticResource ShellHeroCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="MASTER CONTROL · OVERVIEW" Style="{StaticResource ShellEyebrowTextStyle}" />
                    <TextBlock Text="Operational Summary" Style="{StaticResource ShellHeroTitleTextStyle}" />
                    <TextBlock
                        Style="{StaticResource ShellBodyTextStyle}"
                        Foreground="{StaticResource ShellTextMutedBrush}"
                        Text="High-signal state of the orchestration control plane. Drill into Telemetry, Runtime, or CLU for details." />
                    <Border Style="{StaticResource ShellStatusChipStyle}" Margin="0,6,0,0">
                        <TextBlock x:Name="OverviewStatusText"
                                   Style="{StaticResource ShellStatusChipTextStyle}"
                                   Text="WAITING FOR LOCAL SERVICE SYNCHRONIZATION" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Claude Code Control toggle (top of Overview, since it is the
                 single highest-signal action a host operator takes). The
                 ToggleSwitch fires Toggled on every state change including
                 programmatic ones, so the .cpp handler suspends the runtime
                 toggle call while a snapshot-driven IsOn update is pending. -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="CLAUDE CODE CONTROL" Style="{StaticResource ShellEyebrowTextStyle}" />
                    <TextBlock Text="Direct AI Plugin Connection" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock
                        Style="{StaticResource ShellBodyTextStyle}"
                        Foreground="{StaticResource ShellTextMutedBrush}"
                        TextWrapping="WrapWholeWords"
                        Text="Toggle on to register the bundled mcos-control plugin into Claude Code for the current Windows user. The runtime drops a directory junction at %USERPROFILE%\.claude\plugins\mcos-control pointing at the bundled plugin source. Restart Claude Code afterwards. Toggle off removes only the junction." />
                    <ToggleSwitch x:Name="ClaudePluginToggle"
                                  Header="Connect Claude Code to this server"
                                  OnContent="Connected"
                                  OffContent="Disconnected"
                                  Toggled="ClaudePluginToggle_Toggled" />
                    <TextBlock x:Name="ClaudePluginStatusText"
                               Style="{StaticResource ShellDataTextStyle}"
                               TextWrapping="WrapWholeWords"
                               Text="Checking plugin registration state..." />
                    <TextBlock x:Name="ClaudePluginDetailText"
                               Style="{StaticResource ShellDataTextStyle}"
                               Foreground="{StaticResource ShellTextMutedBrush}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <!-- Operational summary narrative -->
            <Border Style="{StaticResource ShellCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="OPERATIONAL SNAPSHOT" Style="{StaticResource ShellEyebrowTextStyle}" />
                    <TextBlock Text="Live State" Style="{StaticResource ShellSectionTitleTextStyle}" />
                    <TextBlock x:Name="OverviewTextBlock"
                               Style="{StaticResource ShellBodyTextStyle}"
                               Text="Loading shell snapshot..." />
                </StackPanel>
            </Border>

            <!-- Environment + Configuration narratives -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="HOST &amp; NETWORK" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Environment Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="EnvironmentNarrativeText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Environment details will populate here." />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="RUNTIME CONFIGURATION" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Configuration Narrative" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="ConfigurationNarrativeText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Configuration details will populate here." />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- v0.8.7 status grid. Four cards arranged 2x2 reporting
                 the live state operator asked for: APIs and services,
                 security stance, MCP server availability, sub-agent
                 availability. Each card has a status dot + a brief
                 read-out populated from snapshot every tick. -->
            <Grid ColumnSpacing="20" RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="APIS &amp; SERVICES" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <Border x:Name="ApiServicesStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                        </StackPanel>
                        <TextBlock Text="Service + Admin API + Gateway" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="ApiServicesText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Loading service + API status..." />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="SECURITY STANCE" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <Border x:Name="SecurityStanceStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                        </StackPanel>
                        <TextBlock Text="Posture + Governance" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="SecurityStanceText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Loading security stance..." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="MCP SERVERS" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <Border x:Name="McpServersStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                        </StackPanel>
                        <TextBlock x:Name="McpServersHeadline" Text="Inventory loading" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="McpServersText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Loading MCP server availability..." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="SUB-AGENTS" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <Border x:Name="SubAgentsStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF8CB7C4" />
                        </StackPanel>
                        <TextBlock x:Name="SubAgentsHeadline" Text="Inventory loading" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock x:Name="SubAgentsText"
                                   Style="{StaticResource ShellDataTextStyle}"
                                   Text="Loading sub-agent availability..." />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- v0.8.7 Error Reporting frame. Lists recent error-flagged
                 events (HTTP 4xx/5xx and 'error'/'failure' kinds harvested
                 from /api/activity in ShellRuntime::CaptureSnapshot).
                 Export-to-JSON button serializes the visible set to
                 %PUBLIC%\Documents\Master Control Orchestration Server\
                 error-export-<timestamp>.json. -->
            <Border Style="{StaticResource ShellCardStyle}" BorderBrush="{StaticResource ShellAccentBrush}">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="ERROR REPORTING" Style="{StaticResource ShellEyebrowTextStyle}" />
                                <Border x:Name="ErrorReportingStatusDot" Width="10" Height="10" CornerRadius="5,5,5,5" VerticalAlignment="Center" Background="#FF1cf2c1" />
                            </StackPanel>
                            <TextBlock x:Name="ErrorReportingHeadline" Text="No errors recorded" Style="{StaticResource ShellSectionTitleTextStyle}" />
                            <TextBlock
                                Style="{StaticResource ShellLabelTextStyle}"
                                Text="HTTP 4xx/5xx events and error-kind activity captured by the local admin API." />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="ExportErrorsButton" Click="ExportErrorsButton_Click" Content="Export to JSON" Style="{StaticResource ShellCommandButtonStyle}" VerticalAlignment="Top" />
                    </Grid>
                    <TextBlock x:Name="ErrorExportStatusText"
                               Style="{StaticResource ShellLabelTextStyle}"
                               Foreground="{StaticResource ShellTextMutedBrush}"
                               TextWrapping="WrapWholeWords"
                               Text="" />
                    <ScrollViewer MaxHeight="280" VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ErrorReportingList" Spacing="6" />
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
