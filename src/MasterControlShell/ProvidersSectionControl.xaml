<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.ProvidersSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="20">
                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="ADD AI MODEL · ACCOUNT SIGN-IN" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Use the Windows app to add Claude or ChatGPT" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock
                            Text="Use this Windows app on the host machine for account sign-in. If the CLI is already signed in, the button below finishes provider registration; otherwise it opens the CLI sign-in prompt. The provider's CLI owns its own tokens, so the orchestration server never sees them."
                            Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                        <!--
                          Three provider cards share one Grid so row heights are
                          computed across ALL columns. Rows are auto-sized by the
                          TALLEST cell in that row, so the button row (Row 3) and
                          the status-footer row (Row 4) end up at the same Y
                          across all three cards regardless of how many lines
                          the header/description above them happen to wrap to.
                          Previously each column was an independent StackPanel
                          flowing top-down, which let buttons land at whatever
                          Y the narrative text stopped at â€” producing the
                          mis-aligned look that the operator rightly flagged.

                          Row budget:
                            Row 0 (Auto): Eyebrow header
                            Row 1 (Auto): Description paragraph (tallest wins)
                            Row 2 (Auto): Status chip or primary input
                            Row 3 (Auto): Primary button(s) â€” always aligned
                            Row 4 (Auto): Footer status line â€” always aligned
                        -->
                        <Grid ColumnSpacing="14" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- ===== CLAUDE column ===== -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                Text="CLAUDE (Pro / Max / Team)" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                Text="Anthropic's coding agent. OAuth sign-in via the Claude Code CLI â€” no API key stored server-side."
                                Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" VerticalAlignment="Top" />
                            <!-- State chip: flipped by RefreshCliInstallStateAsync based on /api/providers/signin/installed. -->
                            <Border Grid.Row="2" Grid.Column="0"
                                x:Name="ClaudeStatusChip" Background="#22FF4444" BorderBrush="#44FF4444" BorderThickness="1" CornerRadius="0" Padding="8,4" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
                                <TextBlock x:Name="ClaudeStatusChipText" Text="CHECKING..." Style="{StaticResource ShellLabelTextStyle}" />
                            </Border>
                            <!-- Only ONE of these two buttons is ever Visible at a time, based on install state. -->
                            <!-- Button labels trimmed so they don't truncate in the narrow column.
                                 The status chip above already conveys the step + install state. -->
                            <Grid Grid.Row="3" Grid.Column="0">
                                <Button x:Name="InstallClaudeCliButton" Click="InstallClaudeCliButton_Click" Content="Install Claude Code CLI" Style="{StaticResource ShellCommandButtonStyle}" HorizontalAlignment="Stretch" />
                                <Button x:Name="SignInWithClaudeButton" Click="SignInWithClaudeButton_Click" Content="Sign in with Claude" Style="{StaticResource ShellCommandButtonStyle}" HorizontalAlignment="Stretch" />
                            </Grid>
                            <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                <ProgressRing x:Name="ClaudeCliProgressRing" Width="18" Height="18" IsActive="False" VerticalAlignment="Center" />
                                <TextBlock x:Name="ClaudeSignInStatusText" Text="Checking..." Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- ===== CHATGPT + CODEX column ===== -->
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                Text="CHATGPT + CODEX (via Codex CLI)" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                Text="One sign-in unlocks both endpoints: ChatGPT for planning &amp; reasoning, Codex for the coding agent."
                                Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" VerticalAlignment="Top" />
                            <Border Grid.Row="2" Grid.Column="1"
                                x:Name="ChatGptStatusChip" Background="#22FF4444" BorderBrush="#44FF4444" BorderThickness="1" CornerRadius="0" Padding="8,4" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
                                <TextBlock x:Name="ChatGptStatusChipText" Text="CHECKING..." Style="{StaticResource ShellLabelTextStyle}" />
                            </Border>
                            <Grid Grid.Row="3" Grid.Column="1">
                                <Button x:Name="InstallCodexCliButton" Click="InstallCodexCliButton_Click" Content="Install Codex CLI" Style="{StaticResource ShellCommandButtonStyle}" HorizontalAlignment="Stretch" />
                                <Button x:Name="SignInWithChatGptButton" Click="SignInWithChatGptButton_Click" Content="Sign in with OpenAI" Style="{StaticResource ShellCommandButtonStyle}" HorizontalAlignment="Stretch" />
                            </Grid>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <ProgressRing x:Name="ChatGptCliProgressRing" Width="18" Height="18" IsActive="False" VerticalAlignment="Center" />
                                <TextBlock x:Name="ChatGptSignInStatusText" Text="Checking..." Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- ===== GROK column ===== -->
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                Text="GROK (xAI API key)" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                Text="xAI does not publish a consumer OAuth flow. Paste your xAI API key once; stored locally with DPAPI encryption."
                                Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" VerticalAlignment="Top" />
                            <PasswordBox Grid.Row="2" Grid.Column="2"
                                x:Name="GrokApiKeyBox" PlaceholderText="xai-..." HorizontalAlignment="Stretch" VerticalAlignment="Bottom" />
                            <Button Grid.Row="3" Grid.Column="2"
                                x:Name="ConnectGrokButton" Click="ConnectGrokButton_Click" Content="Connect Grok" Style="{StaticResource ShellCommandButtonStyle}" HorizontalAlignment="Stretch" />
                            <TextBlock Grid.Row="4" Grid.Column="2"
                                x:Name="GrokConnectStatusText" Text="Waiting for API key." Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="AUTO-CONNECT Â· AI MODEL" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Connect an AI Model" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock
                            Text="Pick a provider and enter your account credentials. The runtime probes the remote endpoint, discovers available models, selects the best match, encrypts credentials with DPAPI, registers the provider, and applies every role you check â€” all in one operation. No base URL, model ID, or route wiring required."
                            Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                        <TextBlock Text="Provider" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox
                            x:Name="QuickConnectProviderSelector"
                            SelectionChanged="QuickConnectProviderSelector_SelectionChanged"
                            PlaceholderText="Choose ChatGPT, Codex, Claude Code, Grok, or generic OpenAI-compatible" />

                        <Border Background="{StaticResource ShellPanelDeepBrush}" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="0" Padding="10,8">
                            <TextBlock
                                x:Name="QuickConnectSummaryText"
                                Style="{StaticResource ShellBodyTextStyle}"
                                Text="Select a provider to preview its default endpoint and recommended model. Everything is automated â€” you only enter credentials and pick roles."
                                TextWrapping="WrapWholeWords" />
                        </Border>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel x:Name="QuickConnectCredentialFieldOnePanel" Spacing="8">
                                <TextBlock x:Name="QuickConnectCredentialFieldOneLabel" Text="Credential" Style="{StaticResource ShellLabelTextStyle}" />
                                <PasswordBox
                                    x:Name="QuickConnectCredentialFieldOneValueBox"
                                    PasswordChanged="QuickConnectCredentialEditor_PasswordChanged"
                                    PlaceholderText="Credential value" />
                                <TextBlock x:Name="QuickConnectCredentialFieldOneHint" Style="{StaticResource ShellDataTextStyle}" Text="" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel x:Name="QuickConnectCredentialFieldTwoPanel" Grid.Column="1" Spacing="8">
                                <TextBlock x:Name="QuickConnectCredentialFieldTwoLabel" Text="Credential" Style="{StaticResource ShellLabelTextStyle}" />
                                <PasswordBox
                                    x:Name="QuickConnectCredentialFieldTwoValueBox"
                                    PasswordChanged="QuickConnectCredentialEditor_PasswordChanged"
                                    PlaceholderText="Credential value" />
                                <TextBlock x:Name="QuickConnectCredentialFieldTwoHint" Style="{StaticResource ShellDataTextStyle}" Text="" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="ASSIGN ROLES" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock
                            Text="Check every role or sub-agent target this model should handle. You can assign the same provider to multiple roles at once â€” the runtime fans the assignments out atomically."
                            Style="{StaticResource ShellLabelTextStyle}"
                            TextWrapping="WrapWholeWords" />
                        <ListView
                            x:Name="AutoConnectRoleSelector"
                            SelectionMode="Multiple"
                            Height="160"
                            BorderBrush="{StaticResource ShellTileEdgeBrush}"
                            BorderThickness="1"
                            Background="{StaticResource ShellPanelDeepBrush}" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ConnectQuickProviderButton" Click="ConnectQuickProviderButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Auto-Connect" HorizontalAlignment="Stretch" />
                            <Button Grid.Column="1" Tag="assign-responsibility" Click="GuidedProviderActionButton_Click" Style="{StaticResource ShellSecondaryButtonStyle}" Content="Manage Assignments" HorizontalAlignment="Stretch" />
                            <Button Grid.Column="2" Tag="configure-autonomy" Click="GuidedProviderActionButton_Click" Style="{StaticResource ShellSecondaryButtonStyle}" Content="Autonomy Settings" HorizontalAlignment="Stretch" />
                        </Grid>

                        <Button Tag="guided-provider-execution" Click="GuidedProviderActionButton_Click" Style="{StaticResource ShellSecondaryButtonStyle}" Content="Validate Routing" HorizontalAlignment="Stretch" />

                        <TextBlock
                            x:Name="QuickConnectStatusText"
                            Style="{StaticResource ShellDataTextStyle}"
                            Text="Ready. Select a provider, enter credentials, pick one or more roles, then press Auto-Connect."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Expander x:Name="ProviderControlsExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
                    <Expander.Header>
                        <StackPanel Spacing="2">
                            <TextBlock Text="PROVIDER CONTROLS" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock Text="Saved routes, credentials, and autonomy settings live here." Style="{StaticResource ShellBodyTextStyle}" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Spacing="20">
                        <Border Style="{StaticResource ShellCardStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Provider Editor" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock Text="Edit a provider route directly â€” only use this when you already know the exact values to change. Most operators should use Auto-Connect above." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                                <TextBlock Text="Provider" Style="{StaticResource ShellLabelTextStyle}" />
                                <ComboBox
                                    x:Name="ProviderSelector"
                                    SelectionChanged="ProviderSelector_SelectionChanged"
                                    PlaceholderText="Choose a provider route" />

                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Provider ID" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBox x:Name="ProviderIdTextBox" TextChanged="ProviderEditor_TextChanged" PlaceholderText="provider-id" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock Text="Kind" Style="{StaticResource ShellLabelTextStyle}" />
                                        <ComboBox x:Name="ProviderKindComboBox" SelectionChanged="ProviderKind_SelectionChanged">
                                            <ComboBoxItem Content="Codex" Tag="codex" />
                                            <ComboBoxItem Content="ChatGPT" Tag="codex" />
                                            <ComboBoxItem Content="Claude Code" Tag="claude_code" />
                                            <ComboBoxItem Content="Grok" Tag="xai" />
                                            <ComboBoxItem Content="Generic" Tag="generic" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Display Name" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="ProviderDisplayNameTextBox" TextChanged="ProviderEditor_TextChanged" PlaceholderText="Display name" />

                                <TextBlock Text="Base URL" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="ProviderBaseUrlTextBox" TextChanged="ProviderEditor_TextChanged" PlaceholderText="https://api.example.com/v1" />

                                <TextBlock Text="Model ID" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="ProviderModelIdTextBox" TextChanged="ProviderEditor_TextChanged" PlaceholderText="Provider recommended model or deployment name" />

                                <StackPanel Orientation="Horizontal" Spacing="18">
                                    <ToggleSwitch x:Name="ProviderEnabledToggle" Header="Enabled" Toggled="ProviderToggle_Toggled" />
                                    <ToggleSwitch x:Name="ProviderAutonomousToggle" Header="Allow autonomous control" Toggled="ProviderToggle_Toggled" />
                                </StackPanel>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="SaveProviderButton" Click="SaveProviderButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Provider" HorizontalAlignment="Stretch" />
                                    <Button x:Name="NewProviderButton" Grid.Column="1" Click="NewProviderButton_Click" Style="{StaticResource ShellSecondaryButtonStyle}" Content="New Provider" HorizontalAlignment="Stretch" />
                                </Grid>

                                <TextBlock x:Name="ProviderEditorStatusText" Style="{StaticResource ShellDataTextStyle}" Text="Provider changes are saved through the local admin API." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShellCardStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Credentials" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock Text="Credentials for the selected route. Secrets stay in the local DPAPI-sealed store." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />
                                <TextBlock x:Name="ProviderCredentialStatusText" Style="{StaticResource ShellDataTextStyle}" Text="Save a provider route to configure credentials." />

                                <StackPanel x:Name="ProviderCredentialFieldOnePanel" Spacing="8">
                                    <TextBlock x:Name="ProviderCredentialFieldOneLabel" Text="Credential Field" Style="{StaticResource ShellLabelTextStyle}" />
                                    <PasswordBox x:Name="ProviderCredentialFieldOneValueBox" PasswordChanged="ProviderCredentialEditor_PasswordChanged" PlaceholderText="Credential value" />
                                    <TextBlock x:Name="ProviderCredentialFieldOneHint" Style="{StaticResource ShellDataTextStyle}" Text="" TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel x:Name="ProviderCredentialFieldTwoPanel" Spacing="8">
                                    <TextBlock x:Name="ProviderCredentialFieldTwoLabel" Text="Credential Field" Style="{StaticResource ShellLabelTextStyle}" />
                                    <PasswordBox x:Name="ProviderCredentialFieldTwoValueBox" PasswordChanged="ProviderCredentialEditor_PasswordChanged" PlaceholderText="Credential value" />
                                    <TextBlock x:Name="ProviderCredentialFieldTwoHint" Style="{StaticResource ShellDataTextStyle}" Text="" TextWrapping="Wrap" />
                                </StackPanel>

                                <Button x:Name="SaveProviderCredentialsButton" Click="SaveProviderCredentialsButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Credentials" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShellCardStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="AI Autonomy" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock Text="Enable this only when you want the connected AI to configure the dashboard itself." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />
                                <ToggleSwitch x:Name="AiAutonomyToggle" Header="Allow dashboard self-configuration" Toggled="AiAutonomyToggle_Toggled" />
                                <Button x:Name="SaveAiAutonomyButton" Click="SaveAiAutonomyButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save AI Autonomy" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="20">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ShellMetricTileStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="PROVIDER ROUTES" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBlock x:Name="ProviderRouteCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                            <TextBlock x:Name="ProviderAutonomyText" Style="{StaticResource ShellLabelTextStyle}" Text="Human-directed" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                        <TextBlock x:Name="ProvidersNarrativeText" Style="{StaticResource ShellBodyTextStyle}" Text="Provider details will populate here." />
                    </Border>
                </Grid>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Provider Connections" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="ProvidersListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="680" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Provider Modules" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="ProviderCapabilitiesListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="260" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Expander x:Name="OrchestrationControlsExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
                    <Expander.Header>
                        <StackPanel Spacing="2">
                            <TextBlock Text="ROLE OWNERSHIP - ORCHESTRATION" Style="{StaticResource ShellEyebrowTextStyle}" />
                            <TextBlock Text="Assign roles, manage specialist groups, and validate provider routing here." Style="{StaticResource ShellBodyTextStyle}" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Spacing="20">
                        <Border Style="{StaticResource ShellCardStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Sub-Agent Groups" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock Text="Create reusable specialist groups so one provider can own a focused lane of sub-agents while other providers control different lanes." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                                <TextBlock Text="Group" Style="{StaticResource ShellLabelTextStyle}" />
                                <ComboBox x:Name="SubAgentGroupSelector" SelectionChanged="SubAgentGroupSelector_SelectionChanged" PlaceholderText="Choose a saved group" />

                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1.2*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Group ID" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBox x:Name="SubAgentGroupIdTextBox" TextChanged="SubAgentGroupEditor_TextChanged" PlaceholderText="swift-specialists" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock Text="Display Name" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBox x:Name="SubAgentGroupDisplayNameTextBox" TextChanged="SubAgentGroupEditor_TextChanged" PlaceholderText="Swift Specialists" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Description" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="SubAgentGroupDescriptionTextBox" TextChanged="SubAgentGroupEditor_TextChanged" AcceptsReturn="True" Height="72" TextWrapping="Wrap" PlaceholderText="Optional notes about the specialty lane or operating doctrine." />

                                <TextBlock Text="Members" Style="{StaticResource ShellLabelTextStyle}" />
                                <ListView x:Name="SubAgentGroupMembersListView" SelectionMode="Multiple" SelectionChanged="SubAgentGroupMembersListView_SelectionChanged" MaxHeight="220" Style="{StaticResource ShellListViewStyle}" />

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="SaveSubAgentGroupButton" Click="SaveSubAgentGroupButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Group" HorizontalAlignment="Stretch" />
                                    <Button x:Name="NewSubAgentGroupButton" Grid.Column="1" Click="NewSubAgentGroupButton_Click" Style="{StaticResource ShellSecondaryButtonStyle}" Content="New Group" HorizontalAlignment="Stretch" />
                                    <Button x:Name="RemoveSubAgentGroupButton" Grid.Column="2" Click="RemoveSubAgentGroupButton_Click" Style="{StaticResource ShellDangerButtonStyle}" Content="Remove Group" HorizontalAlignment="Stretch" />
                                </Grid>

                                <TextBlock x:Name="SubAgentGroupStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No custom sub-agent groups are staged." TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShellCardStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Ownership Routing" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock Text="One provider owns each orchestration role or sub-agent at a time. Group assignments fan out to the current specialist pool." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                                <TextBlock Text="Target" Style="{StaticResource ShellLabelTextStyle}" />
                                <ComboBox x:Name="ProviderAssignmentTargetSelector" SelectionChanged="ProviderAssignmentTargetSelector_SelectionChanged" PlaceholderText="Choose a role or sub-agent" />

                                <TextBlock Text="Owner" Style="{StaticResource ShellLabelTextStyle}" />
                                <ComboBox x:Name="ProviderAssignmentProviderSelector" SelectionChanged="ProviderAssignmentProviderSelector_SelectionChanged" PlaceholderText="Choose the owning provider" />

                                <Button x:Name="SaveProviderAssignmentButton" Click="SaveProviderAssignmentButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Ownership" HorizontalAlignment="Stretch" />

                                <TextBlock x:Name="ProviderAssignmentStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No orchestration ownership changes are staged." />
                                <ListView x:Name="ProviderAssignmentsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="360" Style="{StaticResource ShellListViewStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShellCardStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Execution Console" Style="{StaticResource ShellSectionTitleTextStyle}" />
                                <TextBlock Text="Run a live provider-owned task through the local admin API to validate credentials, ownership routing, and shared MCP access." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.3*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Execution Target" Style="{StaticResource ShellLabelTextStyle}" />
                                        <ComboBox x:Name="ProviderExecutionTargetSelector" SelectionChanged="ProviderExecutionTargetSelector_SelectionChanged" PlaceholderText="Choose a role or sub-agent" />
                                    </StackPanel>

                                    <ToggleSwitch Grid.Column="1" x:Name="ProviderExecutionToolAccessToggle" Header="Shared MCP Access" Toggled="ProviderExecutionEditor_Changed" />

                                    <StackPanel Grid.Column="2" Spacing="8">
                                        <TextBlock Text="Max Turns" Style="{StaticResource ShellLabelTextStyle}" />
                                        <TextBox x:Name="ProviderExecutionMaxTurnsTextBox" Text="4" TextChanged="ProviderExecutionEditor_Changed" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Prompt" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox
                                    x:Name="ProviderExecutionPromptTextBox"
                                    AcceptsReturn="True"
                                    Height="120"
                                    TextWrapping="Wrap"
                                    TextChanged="ProviderExecutionEditor_Changed"
                                    PlaceholderText="Ask the assigned provider to act within its orchestration lane." />

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="ExecuteProviderTaskButton" Click="ExecuteProviderTaskButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Run Provider Task" />
                                    <ProgressRing x:Name="ProviderExecutionProgressRing" Grid.Column="1" Width="22" Height="22" IsActive="False" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                </Grid>

                                <TextBlock x:Name="ProviderExecutionStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No provider task has been executed yet." TextWrapping="Wrap" />
                                <TextBox x:Name="ProviderExecutionOutputTextBox" IsReadOnly="True" AcceptsReturn="True" Height="140" TextWrapping="Wrap" />

                                <TextBlock Text="Execution History" Style="{StaticResource ShellLabelTextStyle}" />
                                <ListView x:Name="ProviderExecutionHistoryListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="260" Style="{StaticResource ShellListViewStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>

