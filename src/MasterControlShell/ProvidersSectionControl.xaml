<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MasterControlShell.ProvidersSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="20">
                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="ADD AI MODEL · ACCOUNT SIGN-IN" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Sign in with your Claude or ChatGPT account" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock
                            Text="One-click sign-in — no API key required. Click a provider below and complete the sign-in prompt in the console window that opens. The provider's CLI owns its own tokens; the orchestration server never sees them."
                            Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="CLAUDE (Pro / Max / Team)" Style="{StaticResource ShellEyebrowTextStyle}" />
                                <Button x:Name="SignInWithClaudeButton" Click="SignInWithClaudeButton_Click" Content="Sign in with Claude account" HorizontalAlignment="Stretch" />
                                <TextBlock x:Name="ClaudeSignInStatusText" Text="Ready." Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="CHATGPT (via Codex CLI)" Style="{StaticResource ShellEyebrowTextStyle}" />
                                <Button x:Name="SignInWithChatGptButton" Click="SignInWithChatGptButton_Click" Content="Sign in with ChatGPT account" HorizontalAlignment="Stretch" />
                                <TextBlock x:Name="ChatGptSignInStatusText" Text="Ready." Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="GROK (xAI API key)" Style="{StaticResource ShellEyebrowTextStyle}" />
                                <TextBlock
                                    Text="xAI does not publish a consumer OAuth flow. Paste your xAI API key once; stored locally with DPAPI encryption."
                                    Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" />
                                <PasswordBox x:Name="GrokApiKeyBox" PlaceholderText="xai-..." />
                                <Button x:Name="ConnectGrokButton" Click="ConnectGrokButton_Click" Content="Connect Grok" HorizontalAlignment="Stretch" />
                                <TextBlock x:Name="GrokConnectStatusText" Text="Waiting for API key." Style="{StaticResource ShellLabelTextStyle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="AUTO-CONNECT · AI MODEL" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock Text="Connect an AI Model" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock
                            Text="Pick a provider and enter your account credentials. The runtime probes the remote endpoint, discovers available models, selects the best match, encrypts credentials with DPAPI, registers the provider, and applies every role you check — all in one operation. No base URL, model ID, or route wiring required."
                            Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                        <TextBlock Text="Provider" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox
                            x:Name="QuickConnectProviderSelector"
                            SelectionChanged="QuickConnectProviderSelector_SelectionChanged"
                            PlaceholderText="Choose ChatGPT, Codex, Claude Code, Grok, or generic OpenAI-compatible" />

                        <Border Background="{StaticResource ShellPanelDeepBrush}" BorderBrush="{StaticResource ShellTileEdgeBrush}" BorderThickness="1" CornerRadius="0" Padding="10,8">
                            <TextBlock
                                x:Name="QuickConnectSummaryText"
                                Style="{StaticResource ShellBodyTextStyle}"
                                Text="Select a provider to preview its default endpoint and recommended model. Everything is automated — you only enter credentials and pick roles."
                                TextWrapping="WrapWholeWords" />
                        </Border>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel x:Name="QuickConnectCredentialFieldOnePanel" Spacing="8">
                                <TextBlock x:Name="QuickConnectCredentialFieldOneLabel" Text="Credential" Style="{StaticResource ShellLabelTextStyle}" />
                                <PasswordBox
                                    x:Name="QuickConnectCredentialFieldOneValueBox"
                                    PasswordChanged="QuickConnectCredentialEditor_PasswordChanged"
                                    PlaceholderText="Credential value" />
                                <TextBlock x:Name="QuickConnectCredentialFieldOneHint" Style="{StaticResource ShellDataTextStyle}" Text="" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel x:Name="QuickConnectCredentialFieldTwoPanel" Grid.Column="1" Spacing="8">
                                <TextBlock x:Name="QuickConnectCredentialFieldTwoLabel" Text="Credential" Style="{StaticResource ShellLabelTextStyle}" />
                                <PasswordBox
                                    x:Name="QuickConnectCredentialFieldTwoValueBox"
                                    PasswordChanged="QuickConnectCredentialEditor_PasswordChanged"
                                    PlaceholderText="Credential value" />
                                <TextBlock x:Name="QuickConnectCredentialFieldTwoHint" Style="{StaticResource ShellDataTextStyle}" Text="" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="ASSIGN ROLES" Style="{StaticResource ShellEyebrowTextStyle}" />
                        <TextBlock
                            Text="Check every role or sub-agent target this model should handle. You can assign the same provider to multiple roles at once — the runtime fans the assignments out atomically."
                            Style="{StaticResource ShellLabelTextStyle}"
                            TextWrapping="WrapWholeWords" />
                        <ListView
                            x:Name="AutoConnectRoleSelector"
                            SelectionMode="Multiple"
                            Height="160"
                            BorderBrush="{StaticResource ShellTileEdgeBrush}"
                            BorderThickness="1"
                            Background="{StaticResource ShellPanelDeepBrush}" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="ConnectQuickProviderButton" Click="ConnectQuickProviderButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Auto-Connect" />
                            <Button Tag="assign-responsibility" Click="GuidedProviderActionButton_Click" Style="{StaticResource ShellSecondaryButtonStyle}" Content="Manage Assignments" />
                            <Button Tag="guided-provider-execution" Click="GuidedProviderActionButton_Click" Style="{StaticResource ShellSecondaryButtonStyle}" Content="Validate Routing" />
                        </StackPanel>

                        <TextBlock
                            x:Name="QuickConnectStatusText"
                            Style="{StaticResource ShellDataTextStyle}"
                            Text="Ready. Select a provider, enter credentials, pick one or more roles, then press Auto-Connect."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Provider Editor" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock Text="Advanced direct provider editor. Use this when you already know the exact route details you want to change." Style="{StaticResource ShellBodyTextStyle}" />

                        <TextBlock Text="Provider" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox
                            x:Name="ProviderSelector"
                            SelectionChanged="ProviderSelector_SelectionChanged"
                            PlaceholderText="Choose a provider route" />

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Provider ID" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="ProviderIdTextBox" TextChanged="ProviderEditor_TextChanged" PlaceholderText="provider-id" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Kind" Style="{StaticResource ShellLabelTextStyle}" />
                                <ComboBox x:Name="ProviderKindComboBox" SelectionChanged="ProviderKind_SelectionChanged">
                                    <ComboBoxItem Content="Codex" Tag="codex" />
                                    <ComboBoxItem Content="ChatGPT" Tag="codex" />
                                    <ComboBoxItem Content="Claude Code" Tag="claude_code" />
                                    <ComboBoxItem Content="Grok" Tag="xai" />
                                    <ComboBoxItem Content="Generic" Tag="generic" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Display Name" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBox x:Name="ProviderDisplayNameTextBox" TextChanged="ProviderEditor_TextChanged" PlaceholderText="Display name" />

                        <TextBlock Text="Base URL" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBox x:Name="ProviderBaseUrlTextBox" TextChanged="ProviderEditor_TextChanged" PlaceholderText="https://api.example.com/v1" />

                        <TextBlock Text="Model ID" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBox x:Name="ProviderModelIdTextBox" TextChanged="ProviderEditor_TextChanged" PlaceholderText="Provider recommended model or deployment name" />

                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <ToggleSwitch x:Name="ProviderEnabledToggle" Header="Enabled" Toggled="ProviderToggle_Toggled" />
                            <ToggleSwitch x:Name="ProviderAutonomousToggle" Header="Allow autonomous control" Toggled="ProviderToggle_Toggled" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="SaveProviderButton" Click="SaveProviderButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Provider" />
                            <Button x:Name="NewProviderButton" Click="NewProviderButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Provider" />
                        </StackPanel>

                        <TextBlock x:Name="ProviderEditorStatusText" Style="{StaticResource ShellDataTextStyle}" Text="Provider changes are saved through the local admin API." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Credentials" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock Text="Credential requirements come from the active provider module through the framework. Secrets stay in the local secure store." Style="{StaticResource ShellBodyTextStyle}" />
                        <TextBlock x:Name="ProviderCredentialStatusText" Style="{StaticResource ShellDataTextStyle}" Text="Save a provider route to configure credentials." />

                        <StackPanel x:Name="ProviderCredentialFieldOnePanel" Spacing="8">
                            <TextBlock x:Name="ProviderCredentialFieldOneLabel" Text="Credential Field" Style="{StaticResource ShellLabelTextStyle}" />
                            <PasswordBox x:Name="ProviderCredentialFieldOneValueBox" PasswordChanged="ProviderCredentialEditor_PasswordChanged" PlaceholderText="Credential value" />
                            <TextBlock x:Name="ProviderCredentialFieldOneHint" Style="{StaticResource ShellDataTextStyle}" Text="" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="ProviderCredentialFieldTwoPanel" Spacing="8">
                            <TextBlock x:Name="ProviderCredentialFieldTwoLabel" Text="Credential Field" Style="{StaticResource ShellLabelTextStyle}" />
                            <PasswordBox x:Name="ProviderCredentialFieldTwoValueBox" PasswordChanged="ProviderCredentialEditor_PasswordChanged" PlaceholderText="Credential value" />
                            <TextBlock x:Name="ProviderCredentialFieldTwoHint" Style="{StaticResource ShellDataTextStyle}" Text="" TextWrapping="Wrap" />
                        </StackPanel>

                        <Button x:Name="SaveProviderCredentialsButton" Click="SaveProviderCredentialsButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Credentials" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="AI Autonomy" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock Text="Enable this only when you want the connected AI to configure the dashboard itself." Style="{StaticResource ShellBodyTextStyle}" />
                        <ToggleSwitch x:Name="AiAutonomyToggle" Header="Allow dashboard self-configuration" Toggled="AiAutonomyToggle_Toggled" />
                        <Button x:Name="SaveAiAutonomyButton" Click="SaveAiAutonomyButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save AI Autonomy" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="20">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ShellMetricTileStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="PROVIDER ROUTES" Style="{StaticResource ShellLabelTextStyle}" />
                            <TextBlock x:Name="ProviderRouteCountText" Style="{StaticResource ShellValueTextStyle}" Text="0" />
                            <TextBlock x:Name="ProviderAutonomyText" Style="{StaticResource ShellLabelTextStyle}" Text="Human-directed" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource ShellCardStyle}">
                        <TextBlock x:Name="ProvidersNarrativeText" Style="{StaticResource ShellBodyTextStyle}" Text="Provider details will populate here." />
                    </Border>
                </Grid>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Provider Connections" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="ProvidersListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="680" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Provider Modules" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <ListView x:Name="ProviderCapabilitiesListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="260" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Sub-Agent Groups" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock Text="Create reusable specialist groups so one provider can own a focused lane of sub-agents while other providers control different lanes." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="WrapWholeWords" />

                        <TextBlock Text="Group" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox x:Name="SubAgentGroupSelector" SelectionChanged="SubAgentGroupSelector_SelectionChanged" PlaceholderText="Choose a saved group" />

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Group ID" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="SubAgentGroupIdTextBox" TextChanged="SubAgentGroupEditor_TextChanged" PlaceholderText="swift-specialists" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Display Name" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="SubAgentGroupDisplayNameTextBox" TextChanged="SubAgentGroupEditor_TextChanged" PlaceholderText="Swift Specialists" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Description" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBox x:Name="SubAgentGroupDescriptionTextBox" TextChanged="SubAgentGroupEditor_TextChanged" AcceptsReturn="True" Height="72" TextWrapping="Wrap" PlaceholderText="Optional notes about the specialty lane or operating doctrine." />

                        <TextBlock Text="Members" Style="{StaticResource ShellLabelTextStyle}" />
                        <ListView x:Name="SubAgentGroupMembersListView" SelectionMode="Multiple" SelectionChanged="SubAgentGroupMembersListView_SelectionChanged" MaxHeight="220" Style="{StaticResource ShellListViewStyle}" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="SaveSubAgentGroupButton" Click="SaveSubAgentGroupButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Group" />
                            <Button x:Name="NewSubAgentGroupButton" Click="NewSubAgentGroupButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="New Group" />
                            <Button x:Name="RemoveSubAgentGroupButton" Click="RemoveSubAgentGroupButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Remove Group" />
                        </StackPanel>

                        <TextBlock x:Name="SubAgentGroupStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No custom sub-agent groups are staged." TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Ownership Routing" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock Text="One provider owns each orchestration role or sub-agent at a time. Group assignments fan out to the current specialist pool." Style="{StaticResource ShellBodyTextStyle}" />

                        <TextBlock Text="Target" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox x:Name="ProviderAssignmentTargetSelector" SelectionChanged="ProviderAssignmentTargetSelector_SelectionChanged" PlaceholderText="Choose a role or sub-agent" />

                        <TextBlock Text="Owner" Style="{StaticResource ShellLabelTextStyle}" />
                        <ComboBox x:Name="ProviderAssignmentProviderSelector" SelectionChanged="ProviderAssignmentProviderSelector_SelectionChanged" PlaceholderText="Choose the owning provider" />

                        <Button x:Name="SaveProviderAssignmentButton" Click="SaveProviderAssignmentButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Save Ownership" />

                        <TextBlock x:Name="ProviderAssignmentStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No orchestration ownership changes are staged." />
                        <ListView x:Name="ProviderAssignmentsListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="360" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Execution Console" Style="{StaticResource ShellSectionTitleTextStyle}" />
                        <TextBlock Text="Run a live provider-owned task through the local admin API to validate credentials, ownership routing, and shared MCP access." Style="{StaticResource ShellBodyTextStyle}" TextWrapping="Wrap" />

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Execution Target" Style="{StaticResource ShellLabelTextStyle}" />
                                <ComboBox x:Name="ProviderExecutionTargetSelector" SelectionChanged="ProviderExecutionTargetSelector_SelectionChanged" PlaceholderText="Choose a role or sub-agent" />
                            </StackPanel>

                            <ToggleSwitch Grid.Column="1" x:Name="ProviderExecutionToolAccessToggle" Header="Shared MCP Access" Toggled="ProviderExecutionEditor_Changed" />

                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="Max Turns" Style="{StaticResource ShellLabelTextStyle}" />
                                <TextBox x:Name="ProviderExecutionMaxTurnsTextBox" Text="4" TextChanged="ProviderExecutionEditor_Changed" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Prompt" Style="{StaticResource ShellLabelTextStyle}" />
                        <TextBox
                            x:Name="ProviderExecutionPromptTextBox"
                            AcceptsReturn="True"
                            Height="120"
                            TextWrapping="Wrap"
                            TextChanged="ProviderExecutionEditor_Changed"
                            PlaceholderText="Ask the assigned provider to act within its orchestration lane." />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="ExecuteProviderTaskButton" Click="ExecuteProviderTaskButton_Click" Style="{StaticResource ShellCommandButtonStyle}" Content="Run Provider Task" />
                        </StackPanel>

                        <TextBlock x:Name="ProviderExecutionStatusText" Style="{StaticResource ShellDataTextStyle}" Text="No provider task has been executed yet." TextWrapping="Wrap" />
                        <TextBox x:Name="ProviderExecutionOutputTextBox" IsReadOnly="True" AcceptsReturn="True" Height="140" TextWrapping="Wrap" />

                        <TextBlock Text="Execution History" Style="{StaticResource ShellLabelTextStyle}" />
                        <ListView x:Name="ProviderExecutionHistoryListView" ItemTemplate="{StaticResource ShellListItemTemplate}" MaxHeight="260" Style="{StaticResource ShellListViewStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
