<?xml version="1.0" encoding="UTF-8"?>
<!--
  Custom actions that invoke MasterControlBootstrapper.exe as a deferred,
  elevated process to handle service registration, firewall rules, module
  manifest placement, and data-directory bootstrap.

  Responsibility split:
    MSI owns → file copy, shortcuts (conditioned components), Programs &
               Features entry (ARPPRODUCTICON + automatic ARP registration),
               upgrade lifecycle.
    Bootstrapper owns → service, firewall, module manifests, data dirs.
      Always invoked with skip-shortcuts + skip-uninstall-registration so
      MSI's ownership is not clobbered.

  Pattern: each deferred CA reads its command line from CustomActionData.
  MSI automatically populates CustomActionData from the value of the property
  whose name matches the deferred CA's Id, when that property is set via
  a preceding immediate SetProperty action. This is the canonical WiX pattern
  for "deferred exec with a command line that depends on install-time
  property state."
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>

    <!--
         WiX canonicalizes directory paths with a trailing backslash, so
         [INSTALLFOLDER] expands to `C:\Program Files\Master Control
         Orchestration Server\`. Quoting that produces `"...Server\"` which
         the CRT CommandLineToArgvW parser reads as an escaped quote,
         the install-dir argument then swallows the next token and
         WixQuietExec64 sees a single merged argv entry like
         `.../Server" (skip-shortcuts-flag)` which the bootstrapper can't
         parse. WixQuietExec64 rolls back the MSI with error 1603.

         Fix: strip the trailing backslash into a dedicated
         INSTALLFOLDER_CLEAN property immediately before composing the
         command line, and reference that instead of [INSTALLFOLDER].
     -->
    <!-- SetProperty CA that copies [INSTALLFOLDER] into INSTALLFOLDER_CLEAN.
         v0.7.5: scheduled After=CostFinalize so it fires in BOTH the
         install and uninstall execute sequences. CostFinalize runs at
         sequence ~1000 in every MSI flow regardless of REMOVE state,
         well before either trim CA. Pre-v0.7.5 this was scheduled
         Before=RunBootstrapperInstall and never ran during uninstall,
         leaving INSTALLFOLDER_CLEAN empty and the uninstall bootstrapper
         CA running with an empty install-directory argument. -->
    <SetProperty Id="INSTALLFOLDER_CLEAN"
                 Value="[INSTALLFOLDER]"
                 After="CostFinalize"
                 Sequence="execute"/>
    <CustomAction Id="TrimInstallFolderTrailingSlash"
                  Script="vbscript"
                  ScriptSourceFile="$(var.InstallerDir)\Fragments\TrimInstallFolder.vbs"
                  Execute="immediate"
                  Return="check"/>
    <!-- v0.7.5: a second CA referencing the same VBScript, scheduled
         before the uninstall path. WiX 5 forbids two Custom entries
         for the same Action ID in InstallExecuteSequence, so we need
         two CustomAction declarations (different IDs) backed by the
         same script file. -->
    <CustomAction Id="TrimInstallFolderTrailingSlashUninstall"
                  Script="vbscript"
                  ScriptSourceFile="$(var.InstallerDir)\Fragments\TrimInstallFolder.vbs"
                  Execute="immediate"
                  Return="check"/>
    <InstallExecuteSequence>
      <Custom Action="TrimInstallFolderTrailingSlash" Before="RunBootstrapperInstall" />
      <Custom Action="TrimInstallFolderTrailingSlashUninstall" Before="RunBootstrapperUninstall" />
    </InstallExecuteSequence>

    <!-- ================================================================
         Install: compose the command line, then run it deferred/elevated.
         ================================================================ -->
    <SetProperty Id="RunBootstrapperInstall"
                 Value="&quot;[#MasterControlBootstrapperExe]&quot; install &quot;[INSTALLFOLDER_CLEAN]&quot; --skip-shortcuts --skip-uninstall-registration[ServiceFlag][FirewallFlag]"
                 Before="RunBootstrapperInstall"
                 Sequence="execute"/>

    <CustomAction Id="RunBootstrapperInstall"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"/>

    <!-- ================================================================
         Uninstall: short, static command — no conditional flags.
         Uses the same trimmed INSTALLFOLDER_CLEAN to avoid the same
         trailing-backslash CommandLineToArgvW quoting hazard.
         ================================================================ -->
    <SetProperty Id="RunBootstrapperUninstall"
                 Value="&quot;[#MasterControlBootstrapperExe]&quot; uninstall &quot;[INSTALLFOLDER_CLEAN]&quot; --skip-shortcuts --skip-uninstall-registration"
                 Before="RunBootstrapperUninstall"
                 Sequence="execute"/>

    <CustomAction Id="RunBootstrapperUninstall"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"/>

    <!-- ================================================================
         Conditional flag helpers. Each SetProperty runs only when the
         operator unchecked the matching Options-dialog checkbox; the
         property stays empty otherwise, and the empty-string expansion
         below turns the install command into a clean no-flag form.
         ================================================================ -->
    <SetProperty Id="ServiceFlag"
                 Value=" --skip-service"
                 After="CostFinalize"
                 Sequence="execute"
                 Condition="INSTALL_SERVICE=&quot;0&quot;"/>
    <SetProperty Id="FirewallFlag"
                 Value=" --skip-firewall"
                 After="CostFinalize"
                 Sequence="execute"
                 Condition="INSTALL_FIREWALL=&quot;0&quot;"/>

  </Fragment>
</Wix>
