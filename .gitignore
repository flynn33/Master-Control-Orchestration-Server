# macOS metadata (defense in depth — if anyone re-zips this Windows repo on a Mac)
__MACOSX/
.DS_Store
._*
**/.DS_Store
**/._*

# Visual Studio
.vs/
*.VC.db
*.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates
*.ipch

# Build output
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
dist/
out/
Testing/
TestResults/
artifacts/

# CMake
CMakeCache.txt
CMakeFiles/
cmake-build-*/
compile_commands.json
CTestTestfile.cmake
cmake_install.cmake
install_manifest.txt

# Generated binaries and symbols
*.obj
*.o
*.pch
*.pdb
*.ilk
*.idb
*.lib
*.exp
*.dll
*.exe
*.appxrecipe
*.winmd

# Logs and temp files
*.log
*.tmp
*.temp
*.bak
*.cache
*.orig
.agent-release*.json
__pycache__/

# NuGet package restore output
packages/

# User-specific CMake presets
CMakeUserPresets.json

# Historical autonomous-session workspace — kept untracked entirely so no
# Local scratch artifacts can slip into the repo. If you need a throwaway work
# area on your clone, this directory is still honored locally but nothing
# inside it is ever committed.
.claude-work/

# Operator-local memory store fed by the project-scoped memory MCP server
# (see .mcp.json). The data file is per-developer scratch, never shipped.
.remember/
/src/MasterControlShell/Directory.Build.props
/src/MasterControlShell/Directory.Build.targets
/src/MasterControlShell/.nuget/
# v0.11.0-alpha.2: CMake-generated #define MASTERCONTROL_VERSION header,
# emitted from VERSION.json at configure time alongside the props/targets
# above. Never edit by hand; rerun cmake to regenerate.
/src/MasterControlShell/GeneratedVersion.h

# Auto-generated by installer/Build-Msi.ps1 — a fresh Files.wxs is emitted
# on every package build so the MSI file list always matches the staged tree.
/installer/Fragments/Files.wxs

# VS Code per-user state. Shared task/launch files are explicitly allowed.
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
