{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(rm -rf .git*)",
      "Bash(del /s /q .git*)",
      "Bash(powershell*Remove-Item*-Recurse*-Force*.git*)"
    ],
    "allow": [
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git rev-list*)",
      "Bash(git branch*)",
      "Bash(git blame*)",
      "Bash(git grep*)",
      "Bash(git ls-files*)",
      "Bash(git fetch*)",
      "Bash(git remote*)",
      "Bash(git for-each-ref*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(grep*)",
      "Bash(awk*)",
      "Bash(sed*)",
      "Bash(find*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(echo*)",
      "Bash(printf*)",
      "Bash(wc*)",
      "Bash(mkdir*)",
      "Bash(py -3*)",
      "Bash(python*)",
      "Bash(node*)",
      "Bash(npm*)",
      "Bash(npx*)",
      "Bash(cmake*)",
      "Bash(ctest*)",
      "PowerShell(*)"
    ]
  },
  "autoMemoryEnabled": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 .claude/scripts/session-start.py"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude/scripts/pool-init.ps1"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo MCOS gate: read CLAUDE.md, manifest.json, and active phase file before editing."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo MCOS pre-edit gate: confirm active phase scope, file-by-file plan, and validation path."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo MCOS stop gate: include files changed, validation results, risks, and next phase status."
          }
        ]
      }
    ]
  }
}